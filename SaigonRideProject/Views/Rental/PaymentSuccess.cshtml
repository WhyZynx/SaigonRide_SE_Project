<div class="container mt-5 text-center">

    <div class="card p-4 shadow-sm">

        <h2 class="text-success">Payment Successful 🎉</h2>

        <h3 class="mt-3">
            @ViewBag.Amount.ToString("N0") VND
        </h3>

        <p class="text-muted">
            @TempData["PaymentMessage"]
        </p>

        <div class="mt-4">

            <a href="/Home/UserDashboard" class="btn btn-primary">
                Back Home
            </a>

            <a href="/Rental/History" class="btn btn-outline-secondary">
                View History
            </a>

        </div>

    </div>

</div>