@model List<SaigonRideProject.ViewModels.StationMapViewModel>

<div class="container-fluid py-5">
    <div class="row g-4 justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div id="map" style="height: 500px; width: 100%;"></div>
                <div class="card-footer bg-white border-0 py-3 px-4">
                    <div class="d-flex gap-4 small fw-medium">
                        <div class="d-flex align-items-center gap-2">
                            <span class="rounded-circle" style="width:10px; height:10px; background-color:#22c55e;"></span>
                            Normal
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="rounded-circle" style="width:10px; height:10px; background-color:#dc3545;"></span>
                            Almost empty
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Stations Nearest You</h5>
                <small class="text-muted">@Model.Count Stations</small>
            </div>

            <div class="overflow-auto pe-2 custom-scrollbar" style="max-height: 600px;">
                @foreach (var s in Model)
                {
                    var occupancyPercent = (s.VehicleCount * 100) / (s.Capacity > 0 ? s.Capacity : 1);
                    var isLow = occupancyPercent < 20;

                    <div class="card mb-3 border-0 shadow-sm rounded-4 hover-card position-relative @(isLow ? "station-low" : "bg-white")" 
                         style="cursor: pointer; transition: 0.2s;"
                         onclick="focusStation(@s.Latitude, @s.Longitude)">
                        
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="pe-5">
                                    <h6 class="fw-bold mb-0 text-dark">@s.Name</h6>
                                    <p class="text-muted small mb-0 mt-1">@s.Address</p>
                                </div>

                                <a href="/Rental/StationDetail/@s.Id" 
                                   class="btn-icon-link" 
                                   onclick="event.stopPropagation();">
                                    <i class="bi bi-arrow-right-short text-dark"></i>
                                </a>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div class="d-flex gap-3 text-secondary small align-items-center">
                                    <span class="badge rounded-pill" 
                                          style="background-color: @(isLow ? "#fff1f2" : "#f0fdf4"); 
                                                 color: @(isLow ? "#e11d48" : "#22c55e"); 
                                                 font-size: 0.7rem; padding: 0.4em 0.8em;">
                                        @occupancyPercent% Full
                                    </span>
                                    <span><i class="bi bi-bicycle me-1 text-primary"></i> @s.VehicleCount</span>
                                    <span><i class="bi bi-lightning-charge me-1 text-warning"></i> @s.AvailableCount</span>
                                </div>
                                
                                @if (isLow)
                                {
                                    <span class="text-danger fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i>LOW STOCK
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8fafc; }
    .custom-scrollbar::-webkit-scrollbar { width: 5px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 10px; }
    
    .station-low { 
        background-color: #fff1f2 !important; 
        border-left: 3px solid #fda4af !important; 
    }

    
    .btn-icon-link {
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 1.8rem;
        transition: 0.2s;
        line-height: 1;
        opacity: 0.6;
    }

    .btn-icon-link:hover {
        transform: translateX(3px);
        opacity: 1;
    }

    .leaflet-popup-content-wrapper { border-radius: 16px !important; padding: 0; overflow: hidden; border: none; }
    .leaflet-popup-tip { display: none; }
</style>

<script>
    let map;

    function initMap() {
        map = L.map('map', { zoomControl: false }).setView([10.7769, 106.7009], 14);
        L.control.zoom({ position: 'bottomright' }).addTo(map);

        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        const stations = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

        stations.forEach(s => {
            const occupancyPercent = (s.VehicleCount * 100) / (s.Capacity > 0 ? s.Capacity : 1);
            const color = occupancyPercent < 20 ? '#dc3545' : '#22c55e';

            const customIcon = L.divIcon({
                className: 'custom-div-icon',
                html: `<div style="background-color: ${color}; width: 20px; height: 20px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 5px rgba(0,0,0,0.2);"></div>`,
                iconSize: [12, 12],
                iconAnchor: [6, 6]
            });

            const popupContent = `
                <div class="p-2" style="min-width: 200px;">
                    <div class="mb-3">
                        <h6 class="fw-bold m-0 text-dark" style="font-size: 0.95rem;">${s.Name}</h6>
                        <p class="text-muted m-0 mt-1" style="font-size: 0.75rem; line-height: 1.4;">
                            <i class="bi bi-geo-alt-fill me-1"></i>${s.Address}
                        </p>
                    </div>
                    <a href="/Rental/StationDetail/${s.Id}" 
                       class="btn btn-dark w-100 rounded-pill py-2 fw-medium" 
                       style="font-size: 0.8rem; letter-spacing: 0.3px;">
                        View Station Detail
                    </a>
                </div>
            `;

            L.marker([s.Latitude, s.Longitude], { icon: customIcon })
                .addTo(map)
                .bindPopup(popupContent);
        });

        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(pos => {
                const userPos = [pos.coords.latitude, pos.coords.longitude];
                L.marker(userPos, {
                    icon: L.icon({
                        iconUrl: "https://cdn-icons-png.flaticon.com/512/7114/7114844.png",
                        iconSize: [30, 30]
                    })
                }).addTo(map);
                map.flyTo(userPos, 15);
            });
        }
    }

    function focusStation(lat, lon) {
        map.flyTo([lat, lon], 17, { duration: 1.2 });
    }

    window.onload = initMap;
</script>