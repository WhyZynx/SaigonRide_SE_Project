@model SaigonRideProject.Models.Rental

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container py-5" style="max-width: 1000px;">
    <div class="text-center mb-5">
        <div class="mb-3">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 4.5rem;"></i>
        </div>
        <h2 class="fw-bold text-dark">Trip Completed Successfully!</h2>
        <p class="text-muted">Thank you for riding with us. Please complete your payment.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="rounded-4 d-flex align-items-center justify-content-center" style="width: 64px; height: 64px; background-color: #f0fdf4;">
                        <i class="bi bi-bicycle text-success fs-1"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0">Vehicle #@Model.VehicleId</h4>
                        <small class="text-muted">Green Edition • SaigonRide</small>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <small class="text-muted d-block mb-1">Pickup Location</small>
                        <span class="fw-bold d-block">@(Model.PickupStation?.Name ?? "Station " + Model.PickupStationId)</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block mb-1">Return Location</small>
                        <span class="fw-bold d-block">@(Model.ReturnStation?.Name ?? "Station " + Model.ReturnStationId)</span>
                    </div>
                    <div class="col-6 mt-3">
                        <small class="text-muted d-block mb-1">Duration</small>
                        <span class="fw-bold">
                            @{
                                var end = Model.EndTime ?? DateTime.Now;
                                var diff = end - Model.StartTime;
                                var totalMinutes = Math.Max(1, Math.Ceiling(diff.TotalMinutes));
                            }
                            @totalMinutes minutes
                        </span>
                    </div>
                    <div class="col-6 mt-3">
                        <small class="text-muted d-block mb-1">Rate</small>
                        <span class="fw-bold">500đ / minute</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-4">Payment Breakdown</h5>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Rental Fee</span>
                    <span class="fw-bold text-dark">@Model.BaseAmount.ToString("N0")đ</span>
                </div>
                <div class="d-flex justify-content-between mb-3 text-success">
                    <span>@(Model.DiscountPercent * 100)% Discount</span>
                    <span class="fw-bold">-@((Model.BaseAmount * Model.DiscountPercent).ToString("N0"))đ</span>
                </div>
                <hr class="my-4" style="border-top: 1px dashed #cbd5e1; opacity: 1;">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="fw-bold mb-0">Total Amount</h4>
                    <h3 class="fw-bold mb-0 text-success">@Model.FinalAmount.ToString("N0")đ</h3>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-3 d-flex flex-row align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-light p-2 rounded-3 text-secondary">
                        <i class="bi bi-wallet2 fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block" style="font-size: 0.7rem; font-weight: 700;">PAYMENT VIA</small>
                        <div id="methodDisplay" class="fw-bold text-dark">@ViewBag.PaymentMethods[0]</div>
                        <select id="paymentMethod" class="form-select form-select-sm border-0 fw-bold p-0 shadow-none d-none" style="background: transparent; width: auto; cursor: pointer;">
                            @foreach (var m in ViewBag.PaymentMethods)
                            {
                                <option value="@m">@m</option>
                            }
                        </select>
                    </div>
                </div>
                <small id="toggleBtn" class="text-success fw-bold px-2 py-1 rounded" style="cursor: pointer;">Change</small>
            </div>
        </div>

        <div class="col-md-6">
            <button class="btn btn-success w-100 py-3 rounded-4 fw-bold shadow-sm" style="background-color: #10B981; border: none; font-size: 1.25rem;" onclick="openQR(@Model.Id)">
                Pay Now • @Model.FinalAmount.ToString("N0")đ
            </button>
        </div>
    </div>
</div>

<div class="modal fade" id="qrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 bg-transparent">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="background-color: #f1f5f9;">
                <div class="modal-header border-0 d-flex justify-content-center position-relative pt-4">
                    <h5 class="fw-bold text-dark m-0">Confirm Your Pay</h5>
                    <button type="button" class="btn-close position-absolute end-0 me-3 shadow-none" data-bs-dismiss="modal" aria-label="Close" style="font-size: 0.8rem;"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="bg-white rounded-4 shadow-sm p-4 text-center">
                        <h4 class="fw-bold mb-4" style="color: #1e293b; letter-spacing: -0.5px;">Transfer Information</h4>
                        <div class="d-inline-block p-2 border rounded-4 mb-4 bg-white shadow-sm">
                            <img id="qrImage" class="img-fluid" style="width: 240px; height: 240px; object-fit: contain;" alt="QR Code" />
                        </div>
                        <div class="text-start mx-auto" style="max-width: 280px;">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Content:</span>
                                <span class="fw-bold text-dark">Payment_SGRide</span>
                            </div>
                            <div class="d-flex justify-content-between mb-4">
                                <span class="text-muted">Payment:</span>
                                <span id="qrMethodDisplay" class="fw-bold text-dark">@ViewBag.PaymentMethods[0]</span>
                            </div>
                        </div>
                        <p class="text-danger small fw-bold mb-0" style="font-size: 0.75rem;">
                            Please keep this page open to confirm your payment.
                        </p>
                    </div>
                    <div class="mt-4">
                        <button class="btn btn-success w-100 py-3 rounded-3 fw-bold border-0 shadow-sm" style="background-color: #059669;" onclick="confirmPaid()">
                            I Have Paid
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="qrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 bg-transparent">
            
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="background-color: #f1f5f9;">
                <div class="modal-header border-0 d-flex justify-content-center position-relative pt-4">
                    <h5 class="fw-bold text-dark m-0">Confirm Your Pay</h5>
                    <button type="button" class="btn-close position-absolute end-0 me-3 shadow-none" data-bs-dismiss="modal" aria-label="Close" style="font-size: 0.8rem;"></button>
                </div>

                <div class="modal-body p-4">
                    <div class="bg-white rounded-4 shadow-sm p-4 text-center">
                        <h4 class="fw-bold mb-4" style="color: #1e293b; letter-spacing: -0.5px;">Transfer Information</h4>
                        
                        <div class="d-inline-block p-2 border rounded-4 mb-4 bg-white shadow-sm">
                            <img id="qrImage" class="img-fluid" style="width: 240px; height: 240px; object-fit: contain;" alt="QR Code" />
                        </div>

                        <div class="text-start mx-auto" style="max-width: 280px;">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Content:</span>
                                <span class="fw-bold text-dark">Payment_SGRide</span>
                            </div>
                            <div class="d-flex justify-content-between mb-4">
                                <span class="text-muted">Payment:</span>
                                <span id="qrAmount" class="fw-bold text-dark"></span>
                            </div>
                        </div>

                        <p class="text-danger small fw-bold mb-0" style="font-size: 0.75rem;">
                            Please keep this page open to confirm your payment.
                        </p>
                    </div>

                    <div class="mt-4">
                        <button class="btn btn-success w-100 py-3 rounded-3 fw-bold border-0 shadow-sm" 
                                style="background-color: #059669;" 
                                onclick="confirmPaid()">
                            I Have Paid
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>


<div class="modal fade" id="qrModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4">

            <h4>Scan to Pay</h4>

            <img id="qrImage" style="width:200px;" />

            <p id="qrAmount" class="mt-2"></p>

            <button class="btn btn-success mt-3" onclick="confirmPaid()">
                I Have Paid
            </button>

        </div>
    </div>
</div>


<style>
    body { background-color: #f8fafc; font-family: 'Inter', sans-serif; }
    .rounded-4 { border-radius: 1.5rem !important; }
    .btn-success:hover { background-color: #047857 !important; transform: translateY(-1px); transition: 0.2s; }
    .form-select:focus { box-shadow: none; }

    #qrModal .modal-content {
        max-width: 420px;
        margin: auto;
    }
    #qrModal .rounded-4 {
        border-radius: 1.5rem !important;
    }
    #qrModal .btn-success:hover {
        background-color: #047857 !important;
        transform: translateY(-1px);
        transition: all 0.2s ease;
    }
    #qrModal .btn-close:focus {
        box-shadow: none;
    }
</style>


<script>
    document.addEventListener('DOMContentLoaded', function () {
        const toggleBtn = document.getElementById('toggleBtn');
        const select = document.getElementById('paymentMethod');
        const display = document.getElementById('methodDisplay');
        const qrDisplay = document.getElementById('qrMethodDisplay');

        toggleBtn.addEventListener('click', function () {
            if (select.classList.contains('d-none')) {
                select.classList.remove('d-none');
                display.classList.add('d-none');
                toggleBtn.innerText = 'Done';
            } else {
                const text = select.options[select.selectedIndex].text;
                display.innerText = text;
                qrDisplay.innerText = text;
                select.classList.add('d-none');
                display.classList.remove('d-none');
                toggleBtn.innerText = 'Change';
            }
        });
    });
</script>

<script src="/js/rental/bill.js"></script>