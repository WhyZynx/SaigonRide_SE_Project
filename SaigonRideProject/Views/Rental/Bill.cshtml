@model SaigonRideProject.Models.Rental

<div class="container mt-5">

    <h2>Trip Summary</h2>

    <p>Base: @Model.BaseAmount.ToString("N0") VND</p>
    <p>Discount: @(Model.DiscountPercent * 100) %</p>

    <h4>Total: @Model.FinalAmount.ToString("N0") VND</h4>

    <div class="mt-3">
        <label>Payment Method</label>

        <select id="paymentMethod" class="form-control">
            @foreach (var m in ViewBag.PaymentMethods)
            {
                <option value="@m">@m</option>
            }
        </select>
    </div>

    <button class="btn btn-success mt-3" onclick="openQR(@Model.Id)">
        Pay Now
    </button>

</div>

<div class="modal fade" id="qrModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4">

            <h4>Scan to Pay</h4>

            <img id="qrImage" style="width:200px;" />

            <p id="qrAmount" class="mt-2"></p>

            <button class="btn btn-success mt-3" onclick="confirmPaid()">
                I Have Paid
            </button>

        </div>
    </div>
</div>

<script src="/js/rental/bill.js"></script>