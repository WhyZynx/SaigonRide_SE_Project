@model SaigonRideProject.ViewModels.StationDetailViewModel

<div class="container mt-4">

    <h2>@Model.Station.Name</h2>
    <p>@Model.Station.Address</p>

    <div class="alert alert-info">
        Capacity: @Model.Capacity |
        Available: @Model.AvailableCount
    </div>

    <div id="map" style="height:400px;margin-bottom:20px"></div>

    <div class="row">

        @foreach (var v in Model.Vehicles)
        {
            <div class="col-md-4">

                <div class="card p-3 mb-3">

                    <h5>@v.VehicleType</h5>

                    <p>
                        Plate: @v.PlateNumber <br />
                        Price: @v.PricePerMinute / min
                    </p>

                    @if (v.Status == "Available")
                    {
                        <a class="btn btn-success w-100"
                               href="/Rental/Start?vehicleId=@v.Id&stationId=@Model.Station.Id">
                            Rent
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary w-100" disabled>
                            Not Available
                        </button>
                    }

                </div>

            </div>
        }

    </div>

</div>
<script>

    let map;
    let userMarker;

    function initMap() {

        const stationPos = [@Model.Station.Latitude, @Model.Station.Longitude];

        map = L.map('map').setView(stationPos, 15);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png')
            .addTo(map);

        L.marker(stationPos)
            .addTo(map)
            .bindPopup("@Model.Station.Name");

        if (navigator.geolocation) {

            navigator.geolocation.getCurrentPosition(
                function (pos) {

                    const userPos = [
                        pos.coords.latitude,
                        pos.coords.longitude
                    ];

                    userMarker = L.marker(userPos, {
                        icon: L.icon({
                            iconUrl: "https://maps.google.com/mapfiles/ms/icons/blue-dot.png"
                        })
                    })
                    .addTo(map)
                    .bindPopup("You are here")
                    .openPopup();

                    L.polyline([userPos, stationPos], {
                        color: 'blue'
                    }).addTo(map);

                },
                function () {
                    console.log("Cannot get location");
                }
            );
        }
    }

    window.onload = initMap;

</script>