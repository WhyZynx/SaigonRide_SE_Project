@model SaigonRideProject.ViewModels.StationDetailViewModel

@{
    var occupancyPercent = (Model.Station.VehicleCount * 100) / (Model.Capacity > 0 ? Model.Capacity : 1);
    var isLow = occupancyPercent < 20;
}

<div class="container py-4">
    <a href="/Rental/StationList" class="text-decoration-none text-muted small mb-3 d-inline-block">
        <i class="bi bi-arrow-left"></i> Back to station list
    </a>

    <div class="mb-4">
        <h1 class="fw-bold mb-1">@Model.Station.Name</h1>
        <p class="text-muted">@Model.Station.Address</p>
    </div>

    <div class="row g-4 align-items-stretch">
        <div class="col-lg-8 d-flex flex-column">
            @if (isLow)
            {
                <div class="alert alert-danger border-0 rounded-3 d-flex align-items-center mb-4" style="background-color: #fff1f2; color: #e11d48;">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <span class="small fw-medium">Low Inventory — Return your vehicle here for 15% discount!</span>
                </div>
            }

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden flex-grow-1">
                <div id="map" style="height: 100%; min-height: 400px; width: 100%; background-color: #e8f5e9;"></div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="row g-3 h-100">
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 p-3">
                        <div class="d-flex gap-3 justify-content-center align-items-center">
                            <div class="flex-fill rounded-4 p-3 text-center" style="background-color: #f8fafc; min-width: 0;">
                                <div class="h2 fw-bold mb-0 text-dark">@Model.Capacity</div>
                                <div class="text-muted small" style="font-size: 0.75rem;">Total Capacity</div>
                            </div>

                            <div class="flex-fill rounded-4 p-3 text-center" style="background-color: #f8fafc; min-width: 0;">
                                <div class="h2 fw-bold mb-0 text-primary">@Model.AvailableCount</div>
                                <div class="text-muted small" style="font-size: 0.75rem;">Available Now</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 p-4 text-center" style="background-color: #fff1f2;">
                        <div class="display-4 fw-bold mb-0" style="color: #e11d48;">@occupancyPercent%</div>
                        <div class="fw-medium" style="color: #e11d48;">Fill Rate</div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                        <h6 class="fw-bold mb-3">Pricing</h6>
                        <div class="d-flex justify-content-between mb-2 small">
                            <span><i class="bi bi-bicycle me-2"></i>Standard Bike</span>
                            <span class="fw-bold">500đ / minute</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span><i class="bi bi-lightning-charge me-2"></i>E-Scooter</span>
                            <span class="fw-bold">1,500đ / minute</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <div class="row align-items-center mb-4 g-3">
            <div class="col-md-auto flex-grow-1">
                <h4 class="fw-bold mb-0 text-truncate">
                    Available Vehicles at @Model.Station.Name
                </h4>
            </div>
    
            <div class="col-md-auto">
                <div class="d-flex gap-2 flex-nowrap justify-content-start justify-content-md-end">
                    <input type="text" id="vehicleSearch" 
                           class="form-control form-control-sm rounded-3 flex-fill flex-md-grow-0" 
                           placeholder="Search ID..." 
                           style="width: 100%; max-width: 180px;">
            
                    <select id="vehicleTypeFilter" 
                            class="form-select form-select-sm rounded-3 flex-fill flex-md-grow-0" 
                            style="width: auto; max-width: 130px;">
                        <option value="">All Types</option>
                        <option value="Bike">Bike</option>
                        <option value="Scooter">Scooter</option>
                    </select>
            
                    <button class="btn btn-primary btn-sm rounded-3 px-3 flex-shrink-0" onclick="applyFilters()">Filter</button>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <table class="table mb-0 align-middle" id="vehicleTable">
                <thead style="background-color: #cbd5e1;">
                    <tr class="small text-uppercase fw-bold text-secondary">
                        <th class="ps-4 border-0 py-3">Vehicle Type</th>
                        <th class="border-0 py-3">Vehicle ID</th>
                        <th class="border-0 py-3">Price</th>
                        <th class="border-0 py-3">Battery</th>
                        <th class="border-0 py-3">Status</th>
                        <th class="text-end pe-4 border-0 py-3">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.Vehicles)
                    {
                        <tr class="vehicle-item" data-type="@v.VehicleType" data-id="@v.PlateNumber">
                        <td class="ps-4 border-bottom-0 py-3 small">@v.VehicleType</td>
                        <td class="border-bottom-0 py-3 small text-muted text-uppercase">@v.PlateNumber</td>
                        <td class="border-bottom-0 py-3 small">@v.PricePerMinute đ / min</td>
                        <td class="border-bottom-0 py-3 small fw-bold @(v.BatteryLevel <= 20 ? "text-danger" : v.BatteryLevel < 50 ? "text-warning" : "text-success")">
                            @v.BatteryLevel%
                        </td>
                        <td class="border-bottom-0 py-3">
                            @if (v.Status == "Available" && v.BatteryLevel > 20)
                            {
                                <span class="badge rounded-pill fw-normal" style="background-color: #f0fdf4; color: #22c55e; padding: 0.5em 1em;">Available</span>
                            }
                            else if (v.BatteryLevel <= 20)
                            {
                                <span class="badge rounded-pill fw-normal" style="background-color: #fef2f2; color: #dc2626; padding: 0.5em 1em;">Maintenance</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill fw-normal" style="background-color: #f8fafc; color: #64748b; padding: 0.5em 1em;">@v.Status</span>
                            }
                        </td>
                        <td class="text-end pe-4 border-bottom-0 py-3">
                            @if (v.Status == "Available" && v.BatteryLevel >= 20)
                            {
                                <a class="btn btn-primary btn-sm rounded-3 px-4 py-2 fw-medium" 
                                   href="/Rental/Start?vehicleId=@v.Id&stationId=@Model.Station.Id">Rent Now</a>
                            }
                            else
                            {
                                <button class="btn btn-light btn-sm rounded-3 px-4 py-2 text-muted" disabled>Unavailable</button>
                            }
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8fafc; }
    .table tbody tr:hover { background-color: #f1f5f9; }
    .btn-primary { background-color: #6495bc; border: none; }
    .btn-primary:hover { background-color: #4a7a9e; }
    .text-primary { color: #6495bc !important; }
    #map { border-radius: 1rem; }
    .leaflet-container { font-family: inherit; }
</style>

<script>
    let map;
    function initMap() {
        const stationPos = [@Model.Station.Latitude, @Model.Station.Longitude];
        map = L.map('map', { zoomControl: false }).setView(stationPos, 16);
        
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        const customIcon = L.divIcon({
            className: 'custom-div-icon',
            html: `<div style="background-color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border: 2px solid #6495bc;">
                    <i class="bi bi-geo-alt-fill" style="color: #6495bc;"></i>
                   </div>`,
            iconSize: [40, 40],
            iconAnchor: [20, 40]
        });

        L.marker(stationPos, { icon: customIcon }).addTo(map);
    }

    function applyFilters() {
        const searchVal = document.getElementById('vehicleSearch').value.toLowerCase();
        const typeVal = document.getElementById('vehicleTypeFilter').value.toLowerCase();
        const rows = document.querySelectorAll('.vehicle-item');

        rows.forEach(row => {
            const id = row.getAttribute('data-id').toLowerCase();
            const type = row.getAttribute('data-type').toLowerCase();
            
            const matchesSearch = id.includes(searchVal);
            const matchesType = typeVal === "" || type.includes(typeVal);

            row.style.display = (matchesSearch && matchesType) ? "" : "none";
        });
    }

    document.getElementById('vehicleSearch').addEventListener('keyup', applyFilters);
    document.getElementById('vehicleTypeFilter').addEventListener('change', applyFilters);

    window.onload = initMap;
</script>