@model SaigonRideProject.ViewModels.CurrentTripViewModel
@using System.Text.Json

<div class="container mt-4">

    <h2>Current Ride</h2>

    <div class="card p-3 mb-3">
        <h4>@Model.VehicleName</h4>
        <p>Start: @Model.StartTime</p>
        <p>Price: @Model.PricePerMinute VND/min</p>

        <h5 id="timer">00:00</h5>
        <h6 id="estimated">Estimated: 0 VND</h6>
    </div>

    <!-- MAP -->
    <div id="map" style="height:400px;" class="mb-3"></div>

    <!-- STATIONS -->
    <h4>Select Return Station</h4>

    <div class="row">
        @foreach (var s in ViewBag.Stations)
        {
            <div class="col-md-4 mb-3">
                <div id="station-@s.id"
                     class="card station-card @(s.isLow ? "border-danger" : "")"
                     onclick="selectStation(@s.id, '@s.name')">

                    <div class="card-body">
                        <h5>@s.name</h5>

                        <div class="progress mb-2">
                            <div class="progress-bar @(s.isLow ? "bg-danger" : "bg-success")"
                                 style="width:@(s.fillPercent * 100)%">
                            </div>
                        </div>

                        <small>
                            @s.currentCount / @s.capacity bikes
                        </small>

                        @if (s.isLow)
                        {
                            <div class="mt-1">
                                <span class="badge bg-danger">
                                    Low Capacity → Discount
                                </span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- SELECTED -->
    <div class="mt-3">
        <strong>Selected:</strong>
        <span id="selectedStationName" class="text-primary">None</span>
    </div>

    <!-- PAYMENT -->
    <div class="mt-3">
        <label>Payment Method</label>
        <select id="paymentMethod" class="form-control">
            @foreach (var m in ViewBag.PaymentMethods)
            {
                <option value="@m">@m</option>
            }
        </select>
    </div>

    <!-- BUTTON -->
    <button class="btn btn-danger mt-3" onclick="endTrip()">
        End Trip
    </button>

    <!-- FORM -->
    <form id="form" method="post" action="/Rental/EndTrip">
        <input type="hidden" name="rentalId" value="@Model.Id" />
        <input type="hidden" id="rs" name="returnStationId" />
        <input type="hidden" id="durationSeconds" name="durationSeconds" />
    </form>

</div>

<!-- DATA -->
<script>
    window.startTime = "@Model.StartTime.ToString("o")";
    window.price = @Model.PricePerMinute;
    window.stations = @Html.Raw(JsonSerializer.Serialize(ViewBag.Stations));
</script>

<!-- LEAFLET -->
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<!-- JS -->
<script src="~/js/rental/currentTrip.js"></script>

<style>
    .station-card {
    cursor: pointer;
    transition: 0.2s;
    }

    .station-card:hover {
    transform: scale(1.03);
    }
</style>