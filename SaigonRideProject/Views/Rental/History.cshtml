@model List<SaigonRideProject.ViewModels.RentalHistoryViewModel>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container mt-5 py-4" style="font-family: 'Segoe UI', Roboto, sans-serif;">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-bold m-0" style="color: #1e293b;">Trip History</h2>
        <span class="badge bg-light text-dark border px-3 py-2 rounded-3">Total: @Model.Count Trips</span>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 1.25rem; overflow: hidden; background: white;">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead style="background-color: #f8fafc; border-bottom: 2px solid #f1f5f9;">
                    <tr style="font-size: 0.85rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">
                        <th class="ps-4 py-3 border-0">Vehicle</th>
                        <th class="py-3 border-0">Plate Number</th>
                        <th class="py-3 border-0">Duration</th>
                        <th class="py-3 border-0">Billing</th>
                        <th class="py-3 border-0">Status</th>
                        <th class="py-3 border-0 pe-4 text-end">Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr style="border-bottom: 1px solid #f1f5f9; transition: all 0.2s;" onmouseover="this.style.backgroundColor='#fcfcfc'" onmouseout="this.style.backgroundColor='transparent'">
                            <td class="ps-4 py-4" style="border: none;">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; background-color: #f0fdf4;">
                                        <i class="bi @(r.VehicleType.Contains("Scooter") ? "bi-scooter" : "bi-bicycle") fs-4" style="color: #10b981;"></i>
                                    </div>
                                    <div>
                                        <span class="fw-bold d-block text-dark">@r.VehicleType</span>
                                        <small class="text-muted">@r.PaymentMethod</small>
                                    </div>
                                </div>
                            </td>
                            <td style="border: none;">
                                <span class="badge bg-light text-secondary border fw-medium px-2 py-1">@r.PlateNumber</span>
                            </td>
                            <td style="border: none;">
                                <div style="font-size: 0.9rem;">
                                    <span class="d-block fw-medium">@r.StartTime.ToString("HH:mm") - @r.EndTime?.ToString("HH:mm")</span>
                                    @{
                                        var duration = (r.EndTime - r.StartTime);
                                        var totalMins = (int)(duration?.TotalMinutes ?? 0);
                                        <small class="text-muted">@totalMins mins</small>
                                    }
                                </div>
                            </td>
                            <td style="border: none;">
                                <div class="d-flex flex-column">
                                    <span class="fw-bold text-dark">@r.FinalAmount.ToString("N0")đ</span>
                                    @if (r.DiscountPercent > 0)
                                    {
                                        <small style="color: #16a34a; font-size: 0.75rem;">
                                            <i class="bi bi-tag-fill me-1"></i>Saved @((r.BaseAmount * r.DiscountPercent).ToString("N0"))đ
                                        </small>
                                    }
                                </div>
                            </td>
                            <td style="border: none;">
                                <span class="badge rounded-pill px-3 py-2" style="font-weight: 600; font-size: 0.7rem; letter-spacing: 0.3px; background-color: #f0fdf4; color: #16a34a;">
                                    <i class="bi bi-check-circle-fill me-1"></i> SUCCESS
                                </span>
                            </td>
                            <td class="pe-4 text-end" style="border: none;">
                                <div class="text-dark fw-medium" style="font-size: 0.9rem;">@r.StartTime.ToString("dd MMM yyyy")</div>
                                <small class="text-muted" style="font-size: 0.8rem;">ID: #@r.StartTime.Ticks.ToString().Substring(12)</small>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f9;
    }
</style>