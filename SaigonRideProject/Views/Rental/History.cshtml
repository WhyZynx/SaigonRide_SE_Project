@model List<SaigonRideProject.ViewModels.RentalHistoryViewModel>
@using System.Text.Json
@using SaigonRideProject.Helpers
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory LocalizerFactory
@{
    var Localizer = LocalizerFactory.Create("SharedResource", "SaigonRideProject");
    ViewData["Title"] = Localizer["TripHistoryTitle"];
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container mt-5 py-4" style="font-family: 'Segoe UI', Roboto, sans-serif;">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-bold m-0" style="color: #1e293b;">@Localizer["TripHistoryTitle"]</h2>
        <span class="badge bg-white text-dark border px-3 py-2 rounded-3 shadow-sm">
            @string.Format(Localizer["TotalTrips"].Value, Model.Count)
        </span>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 1.25rem; background: white;">
        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
            <table class="table align-middle mb-0" style="table-layout: auto;">
                <thead style="position: sticky; top: 0; z-index: 10;">
                    <tr style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px;">
                        <th class="ps-4 py-3 border-0 text-white" style="background-color:#5E96BD; min-width: 180px;">@Localizer["ColVehicle"]</th>
                        <th class="py-3 border-0 text-white" style="background-color:#5E96BD; min-width: 120px;">@Localizer["ColPlateNumber"]</th>
                        <th class="py-3 border-0 text-white" style="background-color:#5E96BD; min-width: 140px;">@Localizer["ColDuration"]</th>
                        <th class="py-3 border-0 text-white" style="background-color:#5E96BD; min-width: 130px;">@Localizer["ColBilling"]</th>
                        <th class="py-3 border-0 text-white text-center" style="background-color:#5E96BD; min-width: 120px;">@Localizer["ColStatus"]</th>
                        <th class="py-3 border-0 pe-4 text-end text-white" style="background-color:#5E96BD; min-width: 130px;">@Localizer["ColDate"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr class="history-row">
                            <td class="ps-4 py-3 border-0">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 42px; height: 42px; background-color: #f0fdf4;">
                                        <i class="bi @(r.VehicleType.Contains("Scooter") ? "bi-scooter" : "bi-bicycle") fs-5" style="color: #10b981;"></i>
                                    </div>
                                    <div class="text-truncate">
                                        <span class="fw-bold d-block text-dark lh-sm">
                                            @(r.VehicleType.Contains("Scooter") ? Localizer["E-Scooter"] : Localizer["Bike"])
                                        </span>
                                        <small class="text-muted" style="font-size: 0.75rem;">
                                            @if (r.PaymentMethod == "Cash")
                                            {
                                                @Localizer["PaymentMethodCash"]
                                            }
                                            else
                                            {
                                                @r.PaymentMethod
                                            }
                                        </small>
                                    </div>
                                </div>
                            </td>
                            <td class="border-0">
                                <span class="badge bg-light text-secondary border fw-medium px-2 py-1" style="font-family: monospace;">@r.PlateNumber</span>
                            </td>
                            <td class="border-0">
                                <div style="font-size: 0.85rem;">
                                    <span class="d-block fw-medium text-nowrap">@r.StartTime.ToString("HH:mm") - @(r.EndTime?.ToString("HH:mm") ?? "--:--")</span>
                                    @{
                                        var duration = (r.EndTime - r.StartTime);
                                        var totalMins = (int)(duration?.TotalMinutes ?? 0);
                                        <small class="text-muted">@totalMins @Localizer["MinsUnit"]</small>
                                    }
                                </div>
                            </td>
                            <td class="border-0">
                                <div class="d-flex flex-column">
                                    <span class="fw-bold text-dark">@r.FinalAmount.ToString("N0") VND</span>
                                    @if (r.DiscountPercent > 0)
                                    {
                                        <small class="text-nowrap" style="color: #16a34a; font-size: 0.7rem;">
                                            <i class="bi bi-tag-fill me-1"></i>
                                            @string.Format(Localizer["SavedAmount"].Value, (r.BaseAmount * r.DiscountPercent).ToString("N0") + " VND")
                                        </small>
                                    }
                                </div>
                            </td>
                            <td class="border-0 text-center">
                                <span class="badge rounded-pill px-2 py-2 w-100" style="max-width: 100px; font-weight: 600; font-size: 0.65rem; background-color: #ecfdf5; color: #059669;">
                                    <i class="bi bi-check-circle-fill me-1"></i> @Localizer["SuccessStatus"]
                                </span>
                            </td>
                            <td class="pe-4 text-end border-0">
                                <div class="text-dark fw-medium text-nowrap" style="font-size: 0.85rem;">@r.StartTime.ToString("dd MMM yyyy")</div>
                                <small class="text-muted" style="font-size: 0.75rem;">#@r.StartTime.Ticks.ToString().Substring(12)</small>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    body { background-color: #f4f7f9; }
    
    .history-row {
        border-bottom: 1px solid #f1f5f9 !important;
        transition: background-color 0.2s;
    }
    .history-row:hover {
        background-color: #f8fafc;
    }

    .table-responsive::-webkit-scrollbar { width: 6px; height: 6px; }
    .table-responsive::-webkit-scrollbar-track { background: #f1f5f9; }
    .table-responsive::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .table-responsive::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

    .text-nowrap { white-space: nowrap; }
</style>