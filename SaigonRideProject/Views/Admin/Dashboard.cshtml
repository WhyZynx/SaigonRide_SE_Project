@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Dashboard</h2>

<div class="row">

    <div class="col-md-3">
        <div class="card p-3">
            <h5>Users</h5>
            <h3>@ViewBag.Users</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <h5>Vehicles</h5>
            <h3>@ViewBag.Vehicles</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <h5>Stations</h5>
            <h3>@ViewBag.Stations</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <h5>Revenue</h5>
            <h3>@ViewBag.Revenue VND</h3>
        </div>
    </div>

</div>