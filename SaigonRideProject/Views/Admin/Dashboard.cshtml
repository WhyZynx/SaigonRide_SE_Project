@model SaigonRideProject.ViewModels.AdminDashboardViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var totalFleet = Model.ActiveRentals + Model.AvailableVehicles;
    var isBusy = Model.ActiveRentals > Model.AvailableVehicles;
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold">System Dashboard</h2>
            <small class="text-muted">
                Last updated: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
            </small>
        </div>

        <div class="d-flex gap-2">
            <div class="btn-group">
                <button class="btn btn-light border dropdown-toggle" data-bs-toggle="dropdown">
                    Filter Time
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="#">Today</a></li>
                    <li><a class="dropdown-item" href="#">Yesterday</a></li>
                    <li><a class="dropdown-item" href="#">Last 7 days</a></li>
                    <li><a class="dropdown-item" href="#">Last 1 month</a></li>
                </ul>
            </div>

            <button class="btn btn-success">
                <i class="bi bi-download"></i> Export
            </button>
        </div>
    </div>

    <!-- KPI -->
    <div class="row g-4">

        <!-- 📈 Active Rentals -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-primary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center"
                             style="width:40px;height:40px;">
                            📈
                        </div>
                        <div class="text-primary fw-medium">Live Rentals</div>
                    </div>

                    <span class="badge bg-success">LIVE</span>
                </div>

                <h1 class="fw-bold mt-4 mb-0 @(isBusy ? "text-danger" : "")">
                    @Model.ActiveRentals
                </h1>

                <p class="text-muted mb-1">vehicles in use</p>

                <small class="text-muted">
                    @Model.AvailableVehicles available • total @totalFleet
                </small>

            </div>
        </div>

        <!-- 💰 Revenue -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <div class="d-flex align-items-center gap-2">
                    <div class="bg-success bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;">
                        💰
                    </div>
                    <div>
                        <div class="text-success fw-medium">Revenue Today</div>
                        <small class="text-muted">
                            @Model.TotalTransactions transactions today
                        </small>
                    </div>
                </div>

                <h2 class="fw-bold mt-4">
                    @String.Format("{0:N0} đ", Model.TodayRevenue)
                </h2>

                <span class="badge bg-success">LIVE</span>

            </div>
        </div>

        <!-- 🚲 Fleet -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <div class="d-flex align-items-center gap-2">
                    <div class="bg-warning bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;">
                        🚲
                    </div>
                    <div class="fw-medium">Fleet Status</div>
                </div>

                <h2 class="fw-bold mt-4">@totalFleet</h2>

                <p class="text-muted mb-1">total fleet size</p>

                <small class="text-muted">
                    @Model.AvailableVehicles available • @Model.ActiveRentals in use
                </small>

            </div>
        </div>

    </div>

    <!-- ⚠️ LOW INVENTORY -->
    <div class="row g-4 mt-3">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100 text-center">

                <div class="mb-2 fs-4">⚠️</div>

                <h2 class="fw-bold text-danger">
                    @(Model.LowStations?.Count() ?? 0)
                </h2>

                <p class="text-muted mb-0">
                    stations need attention
                </p>

            </div>
        </div>
    </div>

    <!-- ALERT -->
    @if (Model.LowStations != null && Model.LowStations.Any())
    {
        <div class="alert alert-danger mt-4 rounded-4">
            <strong>⚠️ Low Inventory Stations:</strong><br />
            @foreach (var s in Model.LowStations)
            {
                <span class="badge bg-danger me-2">@s.StationName</span>
            }
        </div>
    }

    <!-- TABLES -->
    <div class="row g-4 mt-3">

        <!-- LIVE RENTALS -->
        <div class="col-lg-6">
            <div class="card rounded-4 shadow-sm">
                <div class="card-body">
                    <h5 class="mb-3">Live Rentals</h5>

                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>User</th>
                                <th>Vehicle</th>
                                <th>Start</th>
                            </tr>
                        </thead>
                        <tbody>

                            @if (Model.LiveRentals != null && Model.LiveRentals.Any())
                            {
                                foreach (var r in Model.LiveRentals)
                                {
                                    <tr>
                                        <td>@r.UserName</td>
                                        <td>@r.Vehicle</td>
                                        <td>@r.StartTime.ToString("HH:mm dd/MM")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted">
                                        No active rentals
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>

                </div>
            </div>
        </div>

        <!-- TRANSACTIONS -->
        <div class="col-lg-6">
            <div class="card rounded-4 shadow-sm">
                <div class="card-body">
                    <h5 class="mb-3">Recent Transactions</h5>

                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>User</th>
                                <th>Type</th>
                                <th>Amount</th>
                                <th>Time</th>
                            </tr>
                        </thead>
                        <tbody>

                            @if (Model.RecentTransactions != null && Model.RecentTransactions.Any())
                            {
                                foreach (var t in Model.RecentTransactions)
                                {
                                    <tr>
                                        <td>@t.UserName</td>
                                        <td>@t.Type</td>
                                        <td class="fw-semibold">@t.Amount</td>
                                        <td>@t.CreatedAt.ToString("HH:mm dd/MM")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">
                                        No transactions yet
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>

                </div>
            </div>
        </div>

    </div>

</div>