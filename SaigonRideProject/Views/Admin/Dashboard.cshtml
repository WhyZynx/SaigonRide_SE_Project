@model SaigonRideProject.ViewModels.AdminDashboardViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-2">
        <div>
            <h2 class="fw-bold mb-1">📊 System Dashboard</h2>
            <small class="text-muted">
                Last updated: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
            </small>
        </div>

        <button class="btn btn-success">
            <i class="bi bi-download"></i> Export
        </button>
    </div>

    <!-- KPI -->
    <div class="row g-3 mb-4">

        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <small class="text-muted">💰 Revenue Today</small>
                <h4 class="fw-bold text-success mt-2">
                    @Model.TodayRevenue.ToString("N0") đ
                </h4>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <small class="text-muted">📈 Active Rentals</small>
                <h4 class="fw-bold mt-2">
                    @Model.ActiveRentals
                </h4>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <small class="text-muted">🚲 Available Vehicles</small>
                <h4 class="fw-bold mt-2">
                    @Model.AvailableVehicles
                </h4>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <small class="text-muted">🧾 Transactions</small>
                <h4 class="fw-bold mt-2">
                    @Model.TotalTransactions
                </h4>
            </div>
        </div>

    </div>

    <!-- ALERT -->
    @if (Model.LowStations != null && Model.LowStations.Any())
    {
        <div class="alert alert-danger rounded-4 shadow-sm">
            <strong>⚠️ Low Inventory:</strong><br />
            @foreach (var s in Model.LowStations)
            {
                <span class="badge bg-danger me-1">@s.StationName</span>
            }
        </div>
    }

    <!-- TABLES -->
    <div class="row g-4 mt-2">

        <!-- LIVE RENTALS -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">

                    <h5 class="mb-3">📈 Live Rentals</h5>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>User</th>
                                    <th>Vehicle</th>
                                    <th>Start</th>
                                </tr>
                            </thead>
                            <tbody>

                                @if (Model.LiveRentals != null && Model.LiveRentals.Any())
                                {
                                    foreach (var r in Model.LiveRentals)
                                    {
                                        <tr>
                                            <td>@r.UserName</td>
                                            <td>@r.Vehicle</td>
                                            <td>
                                                <small class="text-muted">
                                                    @r.StartTime.ToString("HH:mm dd/MM")
                                                </small>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-3">
                                            No active rentals
                                        </td>
                                    </tr>
                                }

                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>

        <!-- TRANSACTIONS -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">

                    <h5 class="mb-3">💳 Recent Transactions</h5>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>User</th>
                                    <th>Type</th>
                                    <th>Amount</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>

                                @if (Model.RecentTransactions != null && Model.RecentTransactions.Any())
                                {
                                    foreach (var t in Model.RecentTransactions)
                                    {
                                        <tr>
                                            <td>@t.UserName</td>
                                            <td>@t.Type</td>
                                            <td class="fw-semibold text-success">
                                                @t.Amount.ToString("N0")
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    @t.CreatedAt.ToString("HH:mm dd/MM")
                                                </small>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-3">
                                            No transactions yet
                                        </td>
                                    </tr>
                                }

                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>

    </div>

</div>