@model SaigonRideProject.ViewModels.AdminDashboardViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<!-- KPI -->
<div class="row g-3 mb-4">

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small>Today Revenue</small>
                <h5 class="text-success">@Model.TodayRevenue.ToString("N0") đ</h5>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small>Active Rentals</small>
                <h5>@Model.ActiveRentals</h5>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small>Available Vehicles</small>
                <h5>@Model.AvailableVehicles</h5>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small>Total Transactions</small>
                <h5>@Model.TotalTransactions</h5>
            </div>
        </div>
    </div>

</div>

<!-- ALERT -->
@if (Model.LowStations != null && Model.LowStations.Any())
{
    <div class="alert alert-danger">
        Low Inventory:
        @foreach (var s in Model.LowStations)
        {
            <span class="badge bg-danger">@s.StationName</span>
        }
    </div>
}

<!-- TABLES -->
<div class="row g-4">

    <div class="col-md-6">
        <h5>Live Rentals</h5>
        <table class="table table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>User</th>
                    <th>Vehicle</th>
                    <th>Start</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.LiveRentals)
                {
                    <tr>
                        <td>@r.UserName</td>
                        <td>@r.Vehicle</td>
                        <td>@r.StartTime.ToString("HH:mm dd/MM")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="col-md-6">
        <h5>Recent Transactions</h5>
        <table class="table table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>User</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.RecentTransactions)
                {
                    <tr>
                        <td>@t.UserName</td>
                        <td>@t.Type</td>
                        <td>@t.Amount</td>
                        <td>@t.CreatedAt.ToString("HH:mm dd/MM")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>