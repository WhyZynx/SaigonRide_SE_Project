@model SaigonRideProject.ViewModels.AdminDashboardViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold">System Dashboard</h2>
            <small class="text-muted">
                Last updated: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
            </small>
        </div>

        <div class="d-flex gap-2">

            <div class="btn-group">
                <button type="button" class="btn btn-light border dropdown-toggle" data-bs-toggle="dropdown">
                    Filter Time
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="#">Today</a></li>
                    <li><a class="dropdown-item" href="#">Yesterday</a></li>
                    <li><a class="dropdown-item" href="#">Last 7 days</a></li>
                    <li><a class="dropdown-item" href="#">Last 1 month</a></li>
                </ul>
            </div>

            <button class="btn btn-success">
                <i class="bi bi-download"></i> Export
            </button>

        </div>
    </div>

    <div class="row g-4">

        <!-- 📈 Active Rentals -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex justify-content-between">

                    <div>
                        <div class="mb-3 fs-4">📈 <span class="text-primary fw-medium">Live</span></div>

                        <h2 class="fw-bold mb-0">@Model.ActiveRentals</h2>
                        <p class="text-muted mb-0">Active Rentals</p>
                    </div>

                    <div class="text-end">
                        <small class="text-muted">Vehicles in use</small>
                        <p class="fw-medium mb-1">@Model.AvailableVehicles available</p>
                        <small class="text-success">Realtime</small>
                    </div>

                </div>
            </div>
        </div>

        <!-- 💰 Revenue -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <div class="mb-3 fs-4">💰 <span class="text-success fw-medium">Revenue Today</span></div>

                <h2 class="fw-bold">
                    @Model.TodayRevenue.ToString("N0") đ
                </h2>

                <p class="text-muted mb-0">
                    From @Model.TotalTransactions transactions
                </p>

                <small class="text-success">Updated live</small>

            </div>
        </div>

        <!-- 🚲 Vehicles -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <div class="mb-3 fs-4">🚲 <span class="fw-medium">Fleet Availability</span></div>

                <h2 class="fw-bold">@Model.AvailableVehicles</h2>

                <p class="text-muted mb-0">
                    Total: @Model.AvailableVehicles vehicles
                </p>

                <small class="text-danger">Live status</small>

            </div>
        </div>

        <!-- ⚠️ Low Inventory -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <div class="mb-3 fs-4">⚠️ <span class="text-danger fw-medium">Low Inventory</span></div>

                <h2 class="fw-bold text-danger">
                    @(Model.LowStations?.Count() ?? 0)
                </h2>

                <p class="text-muted mb-0">
                    Stations under threshold
                </p>

                <small class="text-danger">Needs attention</small>

            </div>
        </div>

    </div>

    <!-- SMALL STATS -->
    <div class="row g-4 mt-2">

        <div class="col-md-4">
            <div class="card border-danger rounded-4 p-3">
                <h5 class="text-danger mb-1">
                    @(Model.LowStations?.Count() ?? 0) Stations
                </h5>
                <small class="text-muted">Low Inventory</small>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card rounded-4 p-3 text-center">
                <h3 class="fw-bold">@Model.TotalTransactions</h3>
                <small class="text-muted">Total Transactions</small>
            </div>
        </div>

    </div>

    <!-- ALERT -->
    @if (Model.LowStations != null && Model.LowStations.Any())
    {
        <div class="alert alert-danger mt-4 rounded-4">
            <strong>Low Inventory:</strong><br />
            @foreach (var s in Model.LowStations)
            {
                <span class="badge bg-danger me-2">@s.StationName</span>
            }
        </div>
    }

    <!-- TABLES -->
    <div class="row g-4 mt-3">

        <!-- LIVE RENTALS -->
        <div class="col-lg-6">
            <div class="card rounded-4 shadow-sm">
                <div class="card-body">
                    <h5 class="mb-3">Live Rentals</h5>

                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>User</th>
                                <th>Vehicle</th>
                                <th>Start</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.LiveRentals)
                            {
                                <tr>
                                    <td>@r.UserName</td>
                                    <td>@r.Vehicle</td>
                                    <td>@r.StartTime.ToString("HH:mm dd/MM")</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            </div>
        </div>

        <!-- TRANSACTIONS -->
        <div class="col-lg-6">
            <div class="card rounded-4 shadow-sm">
                <div class="card-body">
                    <h5 class="mb-3">Recent Transactions</h5>

                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>User</th>
                                <th>Type</th>
                                <th>Amount</th>
                                <th>Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.RecentTransactions)
                            {
                                <tr>
                                    <td>@t.UserName</td>
                                    <td>@t.Type</td>
                                    <td class="fw-semibold">@t.Amount</td>
                                    <td>@t.CreatedAt.ToString("HH:mm dd/MM")</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            </div>
        </div>

    </div>

</div>