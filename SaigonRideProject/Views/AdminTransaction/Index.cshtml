@model List<SaigonRideProject.ViewModels.AdminTransactionViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var total = Model.Sum(x => x.Amount);
    var income = Model.Where(x => x.Type != "Payment").Sum(x => x.Amount);
    var expense = Model.Where(x => x.Type == "Payment").Sum(x => x.Amount);
}

<h3 class="mb-3">Transaction Management</h3>

<!-- STATS -->
<div class="row mb-4">

    <div class="col-md-4">
        <div class="card shadow-sm p-3">
            <small>Total Volume</small>
            <h5>@total.ToString("N0")</h5>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm p-3">
            <small>Money In</small>
            <h5 class="text-success">+@income.ToString("N0")</h5>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm p-3">
            <small>Money Out</small>
            <h5 class="text-danger">-@expense.ToString("N0")</h5>
        </div>
    </div>

</div>

<!-- FILTER -->
<div class="row mb-3">

    <div class="col-md-6">
        <input id="searchBox" class="form-control"
               placeholder="Search user or ID..." />
    </div>

    <div class="col-md-3">
        <select id="type" class="form-select">
            <option value="">All Types</option>
            <option value="TopUp">TopUp</option>
            <option value="Payment">Payment</option>
            <option value="Refund">Refund</option>
        </select>
    </div>

</div>

<div id="loading" class="text-center mb-2" style="display:none;">
    <small class="text-muted">Loading...</small>
</div>

<div id="transactionTable">
    @Html.Partial("_TransactionTable", Model)
</div>

<script src="~/js/admin-transaction.js"></script>