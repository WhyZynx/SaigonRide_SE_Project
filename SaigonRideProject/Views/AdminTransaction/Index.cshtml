@model List<SaigonRideProject.ViewModels.AdminTransactionViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var total = Model.Sum(x => x.Amount);
    var income = Model.Where(x => x.Type != "Payment").Sum(x => x.Amount);
    var expense = Model.Where(x => x.Type == "Payment").Sum(x => x.Amount);
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-2">
        <div>
            <h3 class="fw-bold mb-1">Transaction Management</h3>
        </div>
    </div>

    <!-- STATS -->
    <div class="row g-3 mb-4">

        <div class="col-6 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Total</div>
                <div class="fs-4 fw-bold">@total.ToString("N0")</div>
            </div>
        </div>

        <div class="col-6 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Money In</div>
                <div class="fs-4 fw-bold text-success">
                    +@income.ToString("N0")
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-muted small">Money Out</div>
                <div class="fs-4 fw-bold text-danger">
                    -@expense.ToString("N0")
                </div>
            </div>
        </div>

    </div>

    <!-- FILTER -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">

            <div class="row g-2">

                <!-- SEARCH -->
                <div class="col-12 col-md-6">
                    <div class="input-group shadow-sm rounded-3 overflow-hidden">
                        <span class="input-group-text border-0 bg-white ps-3">
                            <i class="bi bi-search text-muted"></i>
                        </span>
        
                        <input id="searchBox"
                               type="text"
                               class="form-control border-0 py-2 shadow-none"
                               style="font-size: 0.9rem;" />
                    </div>
                </div>

                <!-- TYPE -->
                <div class="col-6 col-md-3">
                    <select id="type" class="form-select">
                        <option value="">All Types</option>
                        <option value="TopUp">TopUp</option>
                        <option value="Payment">Payment</option>
                        <option value="Refund">Refund</option>
                    </select>
                </div>

            </div>

        </div>
    </div>

    <!-- LOADING -->
    <div id="loading" class="text-center mb-2" style="display:none;">
        <small class="text-muted">Loading...</small>
    </div>

    <!-- TABLE -->
    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-0">

            <!-- QUAN TRỌNG -->
            <div class="table-responsive">
                <div id="transactionTable">
                    @Html.Partial("_TransactionTable", Model)
                </div>
            </div>

        </div>

    </div>

</div>

<script src="~/js/admin-transaction.js"></script>