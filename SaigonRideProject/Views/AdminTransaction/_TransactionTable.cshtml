@model List<SaigonRideProject.ViewModels.AdminTransactionViewModel>

<div class="table-responsive">

    <table class="table align-middle mb-0">

        <!-- HEADER -->
        <thead class="table-light">
            <tr class="text-muted small">
                <th>ID</th>
                <th>User</th>
                <th>Type</th>
                <th>Amount</th>
                <th>Method</th>
                <th>Time</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var t in Model)
            {
                <tr style="cursor:pointer;">

                    <!-- ID -->
                    <td class="fw-semibold text-muted">
                        #@t.Id
                    </td>

                    <!-- USER -->
                    <td>
                        <div class="fw-semibold">@t.UserName</div>
                    </td>

                    <!-- TYPE -->
                    <td>
                        @if (t.Type == "TopUp")
                        {
                            <span class="badge bg-success px-3 py-2">
                                TopUp
                            </span>
                        }
                        else if (t.Type == "Payment")
                        {
                            <span class="badge bg-danger px-3 py-2">
                                Payment
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark px-3 py-2">
                                Refund
                            </span>
                        }
                    </td>

                    <!-- AMOUNT -->
                    <td>
                        @if (t.Type == "Payment")
                        {
                            <span class="fw-bold text-danger">
                                -@t.Amount.ToString("N0")
                            </span>
                        }
                        else
                        {
                            <span class="fw-bold text-success">
                                +@t.Amount.ToString("N0")
                            </span>
                        }
                    </td>

                    <!-- METHOD -->
                    <td>
                        <span class="text-muted">@t.Method</span>
                    </td>

                    <!-- TIME -->
                    <td>
                        <div class="small text-muted">
                            @t.CreatedAt.ToString("dd/MM/yyyy")
                        </div>
                        <div class="small">
                            @t.CreatedAt.ToString("HH:mm")
                        </div>
                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>