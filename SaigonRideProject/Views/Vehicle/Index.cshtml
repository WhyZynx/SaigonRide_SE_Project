@{
    ViewData["Title"] = "Vehicles";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">Our Vehicles</h2>

    <div class="row">

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <img src="~/hình/standardbike.png"
                     class="card-img-top"
                     style="height:300px; object-fit:cover;"
                     alt="Standard Bike" />

                <div class="card-body text-center">
                    <h4>Standard Bike</h4>
                    <p class="mb-2">Comfortable and eco-friendly</p>
                    <h5>500 VND / minute</h5>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <img src="~/images/scooter.png"
                     class="card-img-top"
                     style="height:300px; object-fit:cover;"
                     alt="E-Scooter" />

                <div class="card-body text-center">
                    <h4>E-Scooter</h4>
                    <p class="mb-2">Fast and convenient for city rides</p>
                    <h5>1,500 VND / minute</h5>
                </div>
            </div>
        </div>

    </div>
</div>