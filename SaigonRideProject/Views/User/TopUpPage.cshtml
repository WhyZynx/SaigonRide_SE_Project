@model SaigonRideProject.Models.User

<div class="container mt-4">

    <h2>💰 Top Up Wallet</h2>

    <div class="card p-3 shadow-sm">

        <p>Current Balance: <b>@Model.Balance.ToString("N0") VND</b></p>

        <form method="post" action="/User/TopUp">

            <input type="number"
                   name="amount"
                   class="form-control mb-2"
                   placeholder="Enter amount" />

            <select name="method" class="form-control mb-2">
                @foreach (var method in ViewBag.PaymentMethods as List<string>)
                {
                    <option value="@method">@method</option>
                }
            </select>

            <button class="btn btn-primary w-100">
                Top Up
            </button>

        </form>

    </div>

</div>