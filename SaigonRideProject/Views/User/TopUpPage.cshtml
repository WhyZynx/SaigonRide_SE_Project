@model SaigonRideProject.Models.User

<div class="container py-4 py-md-5">

    <div class="d-flex align-items-start gap-3 mb-3">
        <a asp-controller="User" asp-action="Profile"
               class="btn btn-light rounded-circle shadow-sm p-0 d-flex align-items-center justify-content-center"
               style="width: 40px; height: 40px; flex-shrink: 0;">
            <i class="bi bi-chevron-left text-dark"></i>
        </a>

        <div class="flex-grow-1">
            <div class="row justify-content-center">
                <div class="col-12 col-sm-10 col-md-9 col-lg-6" style="max-width: 550px;">

                    <div class="text-center mb-4">
                        <div class="mb-2">
                            <i class="bi bi-coin text-warning coin-icon"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Top Up Wallet</h2>
                        <p class="text-muted small">Quickly add funds to your account</p>
                    </div>

                    @if (TempData["PaymentMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["PaymentMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                        <div style="height: 6px; background: linear-gradient(90deg, #5E96BD, #A5C9E1);"></div>

                        <div class="card-body p-4 p-md-5">

                            <div class="bg-primary bg-opacity-10 rounded-4 p-4 mb-4 border border-primary border-opacity-10">
                                <div class="d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-2">
                                    <div>
                                        <small class="text-primary d-block fw-bold mb-1 label-balance">AVAILABLE BALANCE</small>
                                        <span class="h4 fw-bold text-dark mb-0">
                                            @Model.Balance.ToString("N0")
                                            <small class="fs-6 fw-normal text-muted">VND</small>
                                        </span>
                                    </div>
                                    <i class="bi bi-wallet-fill text-primary fs-1 opacity-50"></i>
                                </div>
                            </div>

                            <form method="post" asp-controller="User" asp-action="TopUp">

                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-secondary ms-1">Recharge Amount</label>
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-white border-end-0 text-muted px-4" style="border-radius: 12px 0 0 12px;">₫</span>
                                        <input type="number"
                                               name="amount"
                                               class="form-control border-start-0 ps-1 fw-bold"
                                               style="border-radius: 0 12px 12px 0;"
                                               placeholder="0"
                                               required
                                               min="1000" />
                                    </div>
                                    <div class="form-text mt-2 ms-1">Min deposit: 1,000 VND</div>
                                </div>

                                <div class="mb-5">
                                    <label class="form-label small fw-bold text-secondary ms-1">Payment Method</label>
                                    <div class="position-relative">
                                        <select name="method" class="form-select form-select-lg ps-5" style="border-radius: 12px;">
                                            @{
                                                var methods = ViewBag.PaymentMethods as List<string>;
                                            }
                                            @if (methods != null)
                                            {
                                                foreach (var method in methods)
                                                {
                                                    <option value="@method">@method</option>
                                                }
                                            }
                                        </select>
                                        <i class="bi bi-credit-card-2-back position-absolute top-50 start-0 translate-middle-y ms-3 text-muted fs-5"></i>
                                    </div>
                                </div>

                                <button type="submit"
                                        class="btn btn-primary w-100 py-3 fw-bold rounded-3 shadow d-flex align-items-center justify-content-center gap-2">
                                    <i class="bi bi-lightning-charge-fill"></i> Confirm Top Up
                                </button>

                            </form>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <p class="text-muted small mb-0"><i class="bi bi-shield-lock-fill me-1"></i> Secured 256-bit SSL connection</p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f9;
        background-image: radial-gradient(#d1dce5 0.5px, transparent 0.5px);
        background-size: 20px 20px;
    }

    .rounded-4 {
        border-radius: 1.5rem !important;
    }

    .form-control:focus, .form-select:focus {
        border-color: #5E96BD;
        box-shadow: 0 0 0 0.25rem rgba(94, 150, 189, 0.15);
    }

    .btn-primary {
        background-color: #5E96BD;
        border-color: #5E96BD;
        transition: all 0.3s ease;
    }

        .btn-primary:hover {
            background-color: #4a7d9f;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(74, 125, 159, 0.3) !important;
        }

    .coin-icon {
        font-size: 3rem;
    }

    .label-balance {
        font-size: 0.75rem;
        letter-spacing: 0.8px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>