@model List<SaigonRideProject.Models.WalletTransaction>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3 class="mb-4">My Transactions</h3>

<table class="table table-striped table-hover table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Method</th>
            <th>Amount</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>

                <td>
                    @if (t.Type == "TopUp")
                    {
                        <span class="badge bg-success">TopUp</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Payment</span>
                    }
                </td>

                <td>@t.Method</td>

                <td>
                    @if (t.Type == "TopUp")
                    {
                        <span class="text-success">
                            +@Math.Abs(t.Amount).ToString("N0")
                        </span>
                    }
                    else
                    {
                        <span class="text-danger">
                            -@Math.Abs(t.Amount).ToString("N0")
                        </span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>