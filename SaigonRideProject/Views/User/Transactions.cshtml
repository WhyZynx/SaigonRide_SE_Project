@model List<SaigonRideProject.Models.WalletTransaction>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container py-5" style="max-width: 900px; font-family: 'Inter', system-ui, sans-serif;">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">My Transactions</h2>
            <p class="text-muted small mb-0">Track your wallet history and payments</p>
        </div>
        <div class="d-flex align-items-center px-2" style="border-left: 4px solid #808080;">
            <div class="me-3">
                <i class="bi bi-receipt" style="font-size: 1.8rem; color: #808080;"></i>
            </div>
            <div>
                <span class="text-muted d-block" style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; line-height: 1;">
                    Total Activities
                </span>
                <span class="fw-bold text-dark fs-4" style="line-height: 1.2;">
                    @Model.Count <small class="text-secondary fw-normal" style="font-size: 0.9rem;">Transactions</small>
                </span>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                    <tr>
                        <th class="ps-4 py-3 text-muted small fw-bold" style="text-transform: uppercase; letter-spacing: 0.025em;">Activity</th>
                        <th class="py-3 text-muted small fw-bold" style="text-transform: uppercase; letter-spacing: 0.025em;">Method</th>
                        <th class="py-3 text-muted small fw-bold" style="text-transform: uppercase; letter-spacing: 0.025em;">Date</th>
                        <th class="pe-4 py-3 text-muted small fw-bold text-end" style="text-transform: uppercase; letter-spacing: 0.025em;">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        <tr style="transition: all 0.2s; border-bottom: 1px solid #f1f5f9;" onmouseover="this.style.backgroundColor='#fcfcfc'" onmouseout="this.style.backgroundColor='transparent'">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center" 
                                         style="width: 40px; height: 40px; background-color: @(t.Type == "TopUp" ? "#f0fdf4" : "#fef2f2"); color: @(t.Type == "TopUp" ? "#16a34a" : "#dc2626");">
                                        <i class="bi @(t.Type == "TopUp" ? "bi-arrow-down-left-circle" : "bi-cart-check") fs-5"></i>
                                    </div>
                                    <div>
                                        <span class="fw-bold d-block text-dark">@(t.Type == "TopUp" ? "Wallet Top Up" : "Ride Payment")</span>
                                        <span class="text-muted small">#TRX-@t.CreatedAt.Ticks.ToString().Substring(12)</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border fw-medium px-2 py-1" style="font-size: 0.75rem;">
                                    <i class="bi bi-wallet2 me-1"></i> @t.Method
                                </span>
                            </td>
                            <td>
                                <div class="text-dark small fw-medium">@t.CreatedAt.ToString("dd MMM, yyyy")</div>
                                <div class="text-muted" style="font-size: 0.7rem;">@t.CreatedAt.ToString("HH:mm")</div>
                            </td>
                            <td class="pe-4 text-end">
                                <span class="fw-bold fs-5 @(t.Type == "TopUp" ? "text-success" : "text-danger")">
                                    @(t.Type == "TopUp" ? "+" : "-")@Math.Abs(t.Amount).ToString("N0")<small class="ms-1" style="font-size: 0.8rem;">đ</small>
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8fafc; }
    .rounded-4 { border-radius: 1rem !important; }
    .table > :not(caption) > * > * { padding: 1rem 0.5rem; }
</style>