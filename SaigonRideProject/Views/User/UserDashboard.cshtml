@model SaigonRideProject.ViewModels.UserDashboardViewModel

<div class="container mt-4">

    <h2>Welcome, @Model.User.FullName 🚲</h2>

    <div class="row mt-4">

        <div class="col-md-4">

            <div class="card p-3 shadow-sm">

                <h5>Wallet Balance</h5>

                <h3 class="text-primary">
                    @Model.User.Balance.ToString("N0") VND
                </h3>

                <p class="text-muted">
                    Status:
                    @if (Model.User.IsLocked)
                    {
                        <span class="text-danger">Locked</span>
                    }
                    else
                    {
                        <span class="text-success">Active</span>
                    }
                </p>

                <form method="post" action="/User/TopUp">

                    <input type="number"
                           name="amount"
                           class="form-control mb-2"
                           placeholder="Enter amount" />

                    <select name="method" class="form-control mb-2">

                        @if (Model.UserType == "Local")
                        {
                            <option value="MoMo">MoMo</option>
                            <option value="VNPay">VNPay</option>
                            <option value="Cash">Cash</option>
                        }
                        else
                        {
                            <option value="PayPal">PayPal</option>
                            <option value="ApplePay">Apple Pay</option>
                            <option value="Cash">Cash</option>
                        }

                    </select>

                    <button class="btn btn-primary w-100">
                        Top Up
                    </button>

                </form>

            </div>

            <div class="card p-3 mt-3 shadow-sm">

                <h5>Quick Actions</h5>

                <a href="/Rental/StationList" class="btn btn-outline-primary w-100 mb-2">
                    Find Stations
                </a>

                <a href="/Rental/Current" class="btn btn-outline-success w-100 mb-2">
                    My Trip
                </a>

                <a href="/Rental/History" class="btn btn-outline-dark w-100">
                    History
                </a>

            </div>

        </div>

        <div class="col-md-8">

            <div id="map" style="height:500px;border-radius:10px;"></div>

        </div>

    </div>

</div>

<div class="col-md-8">
    <div id="map" style="height:500px;border-radius:10px;"></div>
</div>

<script>

    let map;

    function initMap() {

        map = L.map('map').setView([10.7769, 106.7009], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png')
            .addTo(map);

        const stations = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stations));

        stations.forEach(s => {

            const popup = `
                <b>${s.Name}</b><br/>
                ${s.Address}<br/>
                Available: ${s.AvailableCount}<br/>
                Status: ${s.Status}
            `;

            L.marker([s.Latitude, s.Longitude])
                .addTo(map)
                .bindPopup(popup);
        });
            if (navigator.geolocation) {

        navigator.geolocation.getCurrentPosition(pos => {

            const userPos = [pos.coords.latitude, pos.coords.longitude];

            L.marker(userPos, {
                icon: L.icon({
                    iconUrl: "https://maps.google.com/mapfiles/ms/icons/blue-dot.png"
                })
            })
            .addTo(map)
            .bindPopup("You are here");

            map.setView(userPos, 13);

        });
    }
    }

    function focusStation(lat, lng) {
        map.setView([lat, lng], 16);
    }

    window.onload = initMap;

</script>