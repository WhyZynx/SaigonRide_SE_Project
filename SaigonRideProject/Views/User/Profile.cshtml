@model SaigonRideProject.Models.User

<div class="container py-5" style="max-width: 700px; font-family: 'Inter', system-ui, sans-serif;">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">My Profile</h2>
            <p class="text-muted small mb-0">Manage your personal information</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4">

        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width: 60px; height: 60px; background-color: #f1f5ff; color: #6366f1;">
                <i class="bi bi-person fs-3"></i>
            </div>
            <div>
                <div class="fw-bold text-dark fs-5">@Model.FullName</div>
                <div class="text-muted small">@Model.Email</div>
            </div>
        </div>

        <div class="row g-3">

            <div class="col-md-6">
                <div class="d-flex align-items-center gap-2 text-muted small mb-1">
                    <i class="bi bi-person-badge"></i> User Type
                </div>
                <div class="fw-semibold text-dark">@Model.UserType</div>
            </div>

            <div class="col-md-6">
                <div class="d-flex align-items-center gap-2 text-muted small mb-1">
                    <i class="bi bi-shield-lock"></i> Role
                </div>
                <div class="fw-semibold text-dark">@Model.Role</div>
            </div>

            <div class="col-md-6">
                <div class="d-flex align-items-center gap-2 text-muted small mb-1">
                    <i class="bi bi-wallet2"></i> Balance
                </div>
                <div class="fw-bold text-success fs-5">
                    @Model.Balance.ToString("N0") <small class="text-muted fs-6">VND</small>
                </div>
            </div>

            <div class="col-md-6">
                <div class="d-flex align-items-center gap-2 text-muted small mb-1">
                    <i class="bi bi-lock"></i> Status
                </div>
                <span class="badge @(Model.IsLocked ? "bg-danger-subtle text-danger" : "bg-success-subtle text-success") px-3 py-2">
                    @(Model.IsLocked ? "Locked" : "Active")
                </span>
            </div>

        </div>

    </div>
</div>

<style>
    body { background-color: #f8fafc; }
    .rounded-4 { border-radius: 1rem !important; }
</style>