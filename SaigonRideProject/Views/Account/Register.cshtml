@model SaigonRideProject.ViewModels.RegisterViewModel
@using SaigonRideProject.Data
@using Microsoft.Extensions.Localization
@using SaigonRideProject.Resources

@inject IStringLocalizerFactory LocalizerFactory
@{
    var Localizer = LocalizerFactory.Create("SharedResource", "SaigonRideProject");
    Layout = "Account_Layout";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="card border-0 shadow-lg overflow-hidden" style="border-radius: 40px;">
                <div class="row g-0">

                    <div class="col-md-5 d-none d-md-flex flex-column p-5 text-white position-relative"
                         style="background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.1)), url('/img/city.png') center/cover no-repeat; min-height: 800px;">
                        
                        <div class="mt-5 pt-3">
                            <h1 class="fw-bold display-4 mb-0" style="line-height: 1.1; font-family: sans-serif; letter-spacing: -1px;">
                                @Localizer["RegisterTitle"]
                            </h1>
                        </div>

                        <div class="mt-5 p-4"
                             style="background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 25px; max-width: 380px;">
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-white bg-opacity-25 rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-bicycle fs-5"></i>
                                </div>
                                <div>
                                    <small class="text-uppercase opacity-75 fw-bold" style="font-size: 10px; letter-spacing: 1px;">@Localizer["AvailableFleet"]</small>
                                    <h4 class="fw-bold mb-0">@Localizer["FleetBikes"]</h4>
                                </div>
                            </div>
                            <p class="small mb-0 opacity-100" style="font-size: 13.5px; line-height: 1.6;">
                                @Localizer["FleetSubTitle"]
                            </p>
                        </div>

                        <div class="mt-auto d-flex align-items-center gap-2 mb-2">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle border border-2 border-white bg-secondary" style="width:30px; height:30px;"></div>
                                <div class="rounded-circle border border-2 border-white bg-dark" style="width:30px; height:30px; margin-left: -10px;"></div>
                                <div class="rounded-circle border border-2 border-white bg-info" style="width:30px; height:30px; margin-left: -10px;"></div>
                            </div>
                            <span class="small opacity-75 ms-2" style="font-size: 12px;">@Localizer["TrustedTourists"]</span>
                        </div>
                    </div>

                    <div class="col-md-7 bg-white p-4 p-lg-5">
                        <div class="mb-4">
                            <h2 class="fw-bold text-dark mb-1">@Localizer["CreateAccount"]</h2>
                            <p class="text-muted small">@Localizer["LoginSubTitle"]</p>
                        </div>

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger border-0 small py-2 rounded-3 mb-4 shadow-sm"
                             data-valmsg-summary="true"></div>

                        <form method="post">
                            <div class="row g-3">
                                <div class="col-md-6 mb-2">
                                    <label class="form-label small fw-bold text-secondary text-uppercase" style="font-size: 11px;">@Localizer["FullNameLabel"]</label>
                                    <input asp-for="FullName" class="form-control border-0 bg-light py-3 px-4 shadow-none"
                                           style="border-radius: 15px; background-color: #f0f2f5 !important;" placeholder="Username" />

                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 mb-2">
                                    <label class="form-label small fw-bold text-secondary text-uppercase" style="font-size: 11px;">@Localizer["EmailLabel"]</label>
                                    <input asp-for="Email" class="form-control border-0 bg-light py-3 px-4 shadow-none"
                                           style="border-radius: 15px; background-color: #f0f2f5 !important;" placeholder="abc@example.com" />

                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mb-3 mt-2">
                                <label class="form-label small fw-bold text-secondary text-uppercase" style="font-size: 11px;">@Localizer["PasswordLabel"]</label>
                                <input asp-for="Password" type="password"
                                       class="form-control border-0 bg-light py-3 px-4 shadow-none"
                                       style="border-radius: 15px; background-color: #f0f2f5 !important;" placeholder="••••••••" />

                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                            <small class="text-muted d-block mt-1">
                                @Localizer["PassRequirements"]
                                <ul class="mb-0 ps-3">
                                    <li>@Localizer["ReqLength"]</li>
                                    <li>@Localizer["ReqUpper"]</li>
                                    <li>@Localizer["ReqNumber"]</li>
                                </ul>
                            </small>

                            <div class="mb-3 mt-3">
                                <label class="form-label small fw-bold text-secondary text-uppercase" style="font-size: 11px;">@Localizer["ConfirmPassLabel"]</label>
                                <input asp-for="ConfirmPassword" type="password"
                                       class="form-control border-0 bg-light py-3 px-4 shadow-none"
                                       style="border-radius: 15px; background-color: #f0f2f5 !important;" placeholder="••••••••" />

                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <div class="d-grid mt-5">
                                <button type="submit"
                                        class="btn border-0 py-3 rounded-pill fw-bold text-white shadow"
                                        style="background-color: #446881;">
                                    @Localizer["RegisterBtn"]
                                </button>
                            </div>
                        </form>

                        <div class="mt-4 text-center">
                            <p class="small text-muted">@Localizer["HaveAccount"] <a href="/Account/Login" class="text-dark fw-bold text-decoration-none border-bottom border-dark border-opacity-25">@Localizer["LoginBtn"]</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}