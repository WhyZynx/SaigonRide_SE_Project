@model SaigonRideProject.Models.User

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-body">
            <h3>Register</h3>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form method="post">
                <div class="mb-3">
                    <label>Full Name</label>
                    <input asp-for="FullName" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <input asp-for="Email" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label>Password</label>
                    <input asp-for="PasswordHash" type="password" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label>Confirm Password</label>
                    <input name="confirmPassword" type="password" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label>User Type</label>
                    <select asp-for="UserType"
                            class="form-select"
                            id="userType"
                            onchange="togglePassportField()"
                            required>
                        <option value="">Select User Type</option>
                        <option value="Local">Local</option>
                        <option value="Tourist">Tourist</option>
                    </select>
                </div>

                <div id="passportSection" style="display:none;">
                    <div class="mb-3">
                        <label>Passport Number</label>
                        <input asp-for="PassportNumber"
                               class="form-control"
                               id="passportInput" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    Register
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function togglePassportField() {
        let userType = document.getElementById("userType").value;
        let passportSection = document.getElementById("passportSection");

        if (userType === "Tourist") {
            passportSection.style.display = "block";
        } else {
            passportSection.style.display = "none";
        }
    }

    window.onload = function () {
        togglePassportField();
    };
</script>