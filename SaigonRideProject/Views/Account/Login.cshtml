@using SaigonRideProject.Data
@using Microsoft.Extensions.Localization
@using SaigonRideProject.Resources

@inject IStringLocalizerFactory LocalizerFactory
@{
    var Localizer = LocalizerFactory.Create("SharedResource", "SaigonRideProject");
    Layout = "Account_Layout";
}

@if (ViewBag.Success != null)
{
    <div class="alert alert-success border-0 small py-2 rounded-3 mb-3">
        @ViewBag.Success
    </div>
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="card border-0 shadow-lg overflow-hidden" style="border-radius: 30px;">
                <div class="row g-0">
                    
                    <div class="col-md-6 d-none d-md-flex flex-column justify-content-end p-5 text-white"
                         style="background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.1)), url('/img/city.png') center/cover no-repeat; min-height: 600px;">
                        
                        <div class="p-4 shadow"
                             style="background: rgba(255, 255, 255, 0.2); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.3); border-radius: 25px;">
                            <h2 class="fw-bold mb-2">@Localizer["LoginTitle"]</h2>
                            <p class="small mb-0 opacity-75">@Localizer["LoginSubTitle"]</p>
                        </div>
                        
                        <div class="mt-4 d-flex align-items-center gap-2">
                            <div class="d-flex ms-2">
                                <div class="rounded-circle border border-2 border-white bg-secondary" style="width:30px; height:30px;"></div>
                                <div class="rounded-circle border border-2 border-white bg-dark" style="width:30px; height:30px; margin-left: -10px;"></div>
                                <div class="rounded-circle border border-2 border-white bg-info" style="width:30px; height:30px; margin-left: -10px;"></div>
                            </div>
                            <span class="small opacity-75 fw-light">@Localizer["ActiveRiders"]</span>
                        </div>
                    </div>

                    <div class="col-md-6 bg-white p-4 p-lg-5 d-flex flex-column justify-content-center">
                        <div class="mb-5">
                            <h2 class="fw-bold text-dark mb-1">@Localizer["WelcomeBack"]</h2>
                            <p class="text-muted small">@Localizer["SignInPrompt"]</p>
                        </div>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger border-0 small py-2 rounded-3 mb-4" role="alert">
                                <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error
                            </div>
                        }

                        <form method="post" action="/Account/Login">
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary mb-2" style="font-size: 11px; letter-spacing: 0.5px;">@Localizer["EmailLabel"]</label>
                                <div class="input-group">
                                    <span class="input-group-text border-0 bg-body-secondary rounded-start-pill ps-4">
                                        <i class="fa-regular fa-envelope text-muted"></i>
                                    </span>
                                    <input type="email" name="email"
                                           class="form-control border-0 bg-body-secondary rounded-end-pill py-3 shadow-none"
                                           placeholder="abc@gmail.com" required>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <label class="form-label small fw-bold text-secondary mb-0" style="font-size: 11px; letter-spacing: 0.5px;">@Localizer["PasswordLabel"]</label>
                                    <a href="/Account/ForgotPassword" class="text-decoration-none fw-bold text-secondary" style="font-size: 10px;">@Localizer["ForgotPass"]</a>
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text border-0 bg-body-secondary rounded-start-pill ps-4">
                                        <i class="fa-solid fa-lock text-muted"></i>
                                    </span>
                                    <input type="password" name="password"
                                           class="form-control border-0 bg-body-secondary rounded-end-pill py-3 shadow-none"
                                           placeholder="••••••••" required>
                                </div>
                            </div>

                            <div class="d-grid gap-3 mt-5">
                                <button type="submit" class="btn border-0 py-3 rounded-pill fw-bold text-white shadow-sm"
                                        style="background-color: #446881;">
                                    @Localizer["LoginBtn"]
                                </button>
                                
                                <a href="/Account/Register" class="btn border-0 py-3 rounded-pill fw-bold shadow-sm"
                                   style="background-color: #dee9f3; color: #446881; text-align: center; text-decoration: none;">@Localizer["SignUpBtn"]</a>
                            </div>
                        </form>

                        <div class="mt-5 text-center">
                            <p class="text-muted" style="font-size: 11px;">
                                @Localizer["TermsAgreement"]
                                <a href="#" class="text-dark fw-bold text-decoration-none border-bottom border-dark border-opacity-25">@Localizer["TermsOfService"]</a> và
                                <a href="#" class="text-dark fw-bold text-decoration-none border-bottom border-dark border-opacity-25">@Localizer["PrivacyPolicy"]</a>.
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>