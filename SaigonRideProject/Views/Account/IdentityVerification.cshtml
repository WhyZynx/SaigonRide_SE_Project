@{
    Layout = "_Layout";
    var userType = Context.Session.GetString("UserType");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<div class="vw-100 position-relative start-50 translate-middle-x">
    <div class="row g-0 min-vh-100">
        <div class="col-md-5 d-none d-md-flex position-relative h-100">
         
            <div class="position-absolute top-0 start-0 w-100 h-100 p-5 d-flex flex-column justify-content-between text-white"
                 style="background: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.2)), url('/img/city.png') center/cover no-repeat; min-height: 750px;">

                <div class="mt-5 pt-5 px-3">
                    <h1 class="display-4 fw-bold mb-4" style="line-height: 1.2;">Explore the city <br> with movement.</h1>
                    <p class="fs-5 opacity-75 fw-light">
                        Premium sustainable mobility designed for the urban explorer.
                        Your journey through Saigon's vibrant streets starts with a single click.
                    </p>
                </div>

                <div class="px-3 mb-3 d-flex align-items-center gap-2">
                    <div class="d-flex align-items-center me-2">
                        <img src="https://i.pravatar.cc/40?u=1" class="rounded-circle border border-2 border-white" style="width: 35px; margin-right: -10px;">
                        <img src="https://i.pravatar.cc/40?u=2" class="rounded-circle border border-2 border-white" style="width: 35px; margin-right: -10px;">
                        <img src="https://i.pravatar.cc/40?u=3" class="rounded-circle border border-2 border-white" style="width: 35px;">
                    </div>
                    <span class="small opacity-75">Trusted by 50k+ tourists monthly</span>
                </div>
            </div>
        </div>

        <div class="col-md-7 d-flex align-items-center justify-content-center bg-white h-100">
            <div class="w-100 px-4" style="max-width: 550px;">

                <div class="mb-5 text-center text-md-start">
                    <h2 class="fw-bold text-dark mb-2" style="letter-spacing: -0.5px;">Identity Verification</h2>
                    <p class="text-muted small">
                        Please verify your identity to unlock riding access and ensure safety across the community.
                    </p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 rounded-3 small py-2 mb-4 shadow-sm">
                        <i class="bi bi-exclamation-triangle me-2"></i> @ViewBag.Error
                    </div>
                }

                <form method="post" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">
                            @(userType == "Local" ? "CCCD Number (12 digits)" : "Passport Number (6–12 alphanumeric)")
                        </label>
                        <input type="text" name="identityNumber"
                               class="form-control form-control-lg border-0 rounded-3 shadow-sm"
                               style="background-color: #f3f6ff;"
                               placeholder="Enter your number..." required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">
                            Upload @(userType == "Local" ? "CCCD" : "Passport")
                        </label>
                        <div class="position-relative border border-2 border-dashed rounded-4 p-5 text-center"
                             style="border-style: dashed !important; background-color: #f8fbff; border-color: #d1d9e6 !important;">
                            
                            <i class="bi bi-person-vcard fs-1 text-primary opacity-50 mb-3"></i>
                            <h6 class="fw-bold text-dark mb-1">Passport/ID Upload</h6>
                            <p class="text-muted small mb-3">Click or drag to upload @(userType == "Local" ? "CCCD" : "Passport") Photo.<br>(PDF, JPG, or PNG max 5MB)</p>
                            
                            <input type="file" name="file" class="position-absolute top-0 start-0 w-100 h-100 opacity-0" style="cursor: pointer;" required />
                        </div>
                    </div>

                    <div class="d-flex align-items-start p-3 rounded-3 mb-5" style="background-color: #f1f8f5;">
                        <i class="bi bi-shield-check text-success fs-4 me-3"></i>
                        <div>
                            <h6 class="small fw-bold text-success mb-1">Encrypted & Secure</h6>
                            <p class="mb-0 text-muted" style="font-size: 0.75rem;">Your data is protected using enterprise-grade encryption and will only be used for verification purposes.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <a href="javascript:history.back()" class="btn btn-lg btn-outline-secondary w-100 py-3 rounded-3 border-2 small fw-bold">
                                <i class="bi bi-arrow-left me-2"></i> Back
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <button type="submit" class="btn btn-lg w-100 py-3 rounded-3 text-white shadow border-0 fw-bold"
                                    style="background: linear-gradient(90deg, #72a1cd 0%, #9cbce0 100%);">
                                Submit <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </div>
                </form>

                <div class="text-center mt-5">
                    <p class="small text-muted">Already have an account? <a href="/Login" class="text-primary fw-bold text-decoration-none">Login</a></p>
                </div>

            </div>
        </div>
    </div>
</div>