@using Microsoft.Extensions.Localization
@using SaigonRideProject.Resources
@inject IStringLocalizerFactory LocalizerFactory
@{
    var Localizer = LocalizerFactory.Create("SharedResource", "SaigonRideProject");
    Layout = "Account_Layout";
    var userType = Context.Session.GetString("UserType");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="vw-100 position-relative start-50 translate-middle-x overflow-hidden">
    <div class="row g-0 min-vh-100">
        
        <div class="col-md-6 d-none d-md-flex position-relative">
            <div class="position-absolute top-0 start-0 w-100 h-100 p-5 d-flex flex-column justify-content-between text-white"
                 style="background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.4)), url('/img/city.png') center/cover no-repeat;">

                <div class="mt-5 pt-5 px-lg-4">
                    <h1 class="display-4 fw-bold mb-4" style="line-height: 1.2;">@Html.Raw(Localizer["VerifyOtpTitle"].Value.Replace("city your", "city <br> with"))</h1>
                    <p class="fs-5 opacity-75 fw-light w-100">
                        @Localizer["SelectionSubTitle"]
                    </p>
                </div>

                <div class="px-lg-4 mb-5 d-flex align-items-center gap-2">
                    <div class="d-flex align-items-center me-2">
                        <div class="rounded-circle border border-2 border-white bg-secondary" style="width:30px; height:30px;"></div>
                        <div class="rounded-circle border border-2 border-white bg-dark" style="width:30px; height:30px; margin-left: -10px;"></div>
                        <div class="rounded-circle border border-2 border-white bg-info" style="width:30px; height:30px; margin-left: -10px;"></div>
                    </div>
                    <span class="small opacity-75">@Localizer["TrustedTourists"]</span>
                </div>
            </div>
        </div>

        <div class="col-md-6 d-flex align-items-center justify-content-center bg-white border-start">
            <div class="w-100 px-4 px-lg-5 py-5" style="max-width: 500px;">
                <div class="mb-5 text-center text-md-start">
                    <h2 class="fw-bold text-dark mb-2" style="letter-spacing: -0.5px;">@Localizer["IdentityHeader"]</h2>
                    <p class="text-muted small">
                        @Localizer["IdentitySubTitle"]
                    </p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 rounded-3 small py-2 mb-4 shadow-sm">
                        <i class="bi bi-exclamation-triangle me-2"></i> @ViewBag.Error
                    </div>
                }

                <form method="post" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">
                            @(userType == "Local" ? Localizer["LocalIdLabel"] : Localizer["PassportIdLabel"])
                        </label>
                        <input type="text" name="identityNumber"
                               class="form-control form-control-lg border-0 rounded-3 shadow-sm"
                               style="background-color: #f3f6ff;"
                               placeholder="@Localizer["IdNumberPlaceholder"]" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">
                            @Localizer["UploadDocLabel"]
                        </label>
                        <div id="dropzone" class="position-relative border border-2 border-dashed rounded-4 p-2 text-center"
                             style="border-style: dashed !important; background-color: #f8fbff; border-color: #d1d9e6 !important; min-height: 300px; display: flex; align-items: center; justify-content: center;">
                            
                            <div id="default-content">
                                <i class="bi bi-person-vcard fs-1 text-primary opacity-50 mb-3"></i>
                                <h6 class="fw-bold text-dark mb-1">@(userType == "Local" ? "CCCD" : "Passport")</h6>
                                <p class="text-muted small mb-3">@Localizer["UploadPrompt"]</p>
                            </div>

                            <img id="preview-img" src="#" alt="Preview"
                                 class="d-none img-fluid rounded-3 w-100 h-100"
                                 style="max-height: 280px; object-fit: contain; z-index: 10;">
                            
                            <input type="file" name="file" id="file-input"
                                   class="position-absolute top-0 start-0 w-100 h-100 opacity-0"
                                   style="cursor: pointer; z-index: 20;" accept="image/*" required />
                        </div>
                    </div>

                    <div class="d-flex align-items-start p-3 rounded-3 mb-5" style="background-color: #f1f8f5;">
                        <i class="bi bi-shield-check text-success fs-4 me-3"></i>
                        <div>
                            <h6 class="small fw-bold text-success mb-1">@Localizer["SecureTitle"]</h6>
                            <p class="mb-0 text-muted" style="font-size: 0.75rem;">@Localizer["SecureDesc"]</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <a href="javascript:history.back()" class="btn btn-lg btn-outline-secondary w-100 py-3 rounded-3 border-2 small fw-bold d-flex justify-content-center align-items-center">
                                <i class="bi bi-arrow-left me-2"></i> @Localizer["BackBtn"]
                            </a>
                        </div>
                        <div class="col-6">
                            <button type="submit" class="btn btn-lg w-100 py-3 rounded-3 text-white shadow border-0 fw-bold d-flex justify-content-center align-items-center"
                                    style="background: linear-gradient(90deg, #72a1cd 0%, #9cbce0 100%);">
                                @Localizer["SubmitBtn"] <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </div>
                </form>

                @section Scripts {
                    <script>
                        document.getElementById('file-input').onchange = evt => {
                            const [file] = evt.target.files;
                            if (file) {
                                const preview = document.getElementById('preview-img');
                                const defaultContent = document.getElementById('default-content');
                                preview.src = URL.createObjectURL(file);
                                preview.classList.remove('d-none');
                                defaultContent.classList.add('d-none');
                            }
                        }
                    </script>
                }
            </div>
        </div>

    </div>
</div>