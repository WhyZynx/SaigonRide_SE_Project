@model SaigonRideProject.ViewModels.ForgotPasswordViewModel
@{
    var email = ViewBag.Email as string;
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">

            <div class="card border-0 shadow-lg overflow-hidden" style="border-radius: 30px;">
                <div class="row g-0">

                    <div class="col-md-6 d-none d-md-flex flex-column justify-content-end p-5 text-white"
                         style="background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.1)), url('/img/HCM.png') center/cover no-repeat; min-height: 600px;">
                    </div>

                    <div class="col-md-6 bg-white p-4 p-lg-5 d-flex flex-column justify-content-center">

                        <h2 class="fw-bold mb-1">Forgot Password</h2>
                        <p class="text-muted small mb-4">Reset your password securely</p>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger py-2 small">
                                @ViewBag.Error
                            </div>
                        }

                        @if (ViewBag.Success != null)
                        {
                            <div class="alert alert-success py-2 small">
                                @ViewBag.Success
                            </div>
                        }

                        <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                        @* ================= STEP 1 ================= *@
                        @if (string.IsNullOrEmpty(email))
                        {
                            <form method="post" action="/Account/SendForgotOtp">

                                @Html.AntiForgeryToken()

                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-secondary">EMAIL</label>

                                    <input name="email"
                                           class="form-control bg-body-secondary border-0 py-3 rounded-pill shadow-none"
                                           placeholder="Enter your email"
                                           required />
                                </div>

                                <button type="submit"
                                        class="btn w-100 py-3 rounded-pill fw-bold text-white"
                                        style="background-color:#446881;">
                                    Send OTP
                                </button>
                            </form>
                        }

                        @* ================= STEP 2 ================= *@
                        @if (!string.IsNullOrEmpty(email))
                        {
                            <form method="post" action="/Account/ForgotPassword">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="Email" value="@email" />

                                <div class="mb-2">
                                    <small class="text-muted">
                                        OTP sent to: <b>@email</b>
                                    </small>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-secondary">OTP</label>
                                    <input asp-for="OtpCode"
                                           class="form-control bg-body-secondary border-0 py-3 rounded-pill shadow-none" />
                                    <span asp-validation-for="OtpCode" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-secondary">NEW PASSWORD</label>
                                    <input asp-for="NewPassword" type="password"
                                           class="form-control bg-body-secondary border-0 py-3 rounded-pill shadow-none" />
                                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-secondary">CONFIRM PASSWORD</label>
                                    <input asp-for="ConfirmPassword" type="password"
                                           class="form-control bg-body-secondary border-0 py-3 rounded-pill shadow-none" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>

                                <button type="submit"
                                        class="btn w-100 py-3 rounded-pill fw-bold text-white"
                                        style="background-color:#446881;">
                                    Reset Password
                                </button>
                            </form>
                        }

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>