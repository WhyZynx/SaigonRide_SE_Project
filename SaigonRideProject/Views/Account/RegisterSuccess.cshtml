@{
    Layout = "Account_Layout";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="vw-100 position-relative start-50 translate-middle-x">
    <div class="row g-0 min-vh-100">
        <div class="col-md-6 d-none d-md-flex align-items-center p-5 position-relative"
             style="background: linear-gradient(rgba(62, 99, 125, 0.4), rgba(62, 99, 125, 0.8)), url('/img/city.png') center/cover no-repeat;">
            <div class="ps-lg-5">
                <h1 class="display-3 fw-bold text-white mb-0" style="line-height: 1.1; letter-spacing: -1px;">
                    Discover the city<br>your own way.
                </h1>
            </div>
        </div>

        <div class="col-12 col-md-6 d-flex align-items-start justify-content-center bg-white min-vh-100 pt-5 mt-lg-5">
            <div class="text-start px-4" style="max-width: 480px;">
                <div class="mb-4">
                    <div class="d-flex align-items-center justify-content-center rounded-circle shadow"
                         style="width: 70px; height: 70px; background-color: #72a1cd; box-shadow: 0 10px 25px rgba(114, 161, 205, 0.4) !important;">
                        <div class="d-flex align-items-center justify-content-center rounded-circle bg-white"
                             style="width: 28px; height: 28px;">
            
                            <i class="bi bi-check-lg" style="color: #72a1cd; font-size: 18px; -webkit-text-stroke: 1.5px;"></i>
                        </div>
                    </div>
                </div>

                <h2 class="fw-bold mb-3 text-dark">Registration Successful!</h2>
                
                <p class="text-muted mb-5 fs-6" style="line-height: 1.6;">
                    Welcome to the SaigonRide community. You're now ready to start your eco-friendly journey.
                </p>

                <div>
                    <a href="/User/UserDashboard"
                           class="btn btn-lg w-100 py-3 fw-bold text-white shadow-sm border-0 d-flex justify-content-center align-items-center"
                           style="background: linear-gradient(90deg, #72a1cd 0%, #9cbce0 100%); border-radius: 12px;">
                        Start Now <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>