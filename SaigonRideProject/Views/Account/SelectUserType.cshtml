@using SaigonRideProject.Data
@using Microsoft.Extensions.Localization
@using SaigonRideProject.Resources

@inject IStringLocalizerFactory LocalizerFactory
@{
    var Localizer = LocalizerFactory.Create("SharedResource", "SaigonRideProject");
    Layout = "Account_Layout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="vw-100 position-relative start-50 translate-middle-x">
    <div class="row g-0 min-vh-100">

        <div class="col-md-6 d-none d-md-flex position-relative text-white"
             style="
            background: linear-gradient(
            rgba(62, 99, 125, 0.2),
            rgba(62, 99, 125, 0.7)
            ),
            url('/img/city.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            min-height: 100vh;
            ">

            <div class="d-flex flex-column justify-content-end h-100 w-100 p-5">
                <div class="mb-4">
                    <h1 class="display-4 fw-bold mb-3 lh-sm">
                        @Localizer["SelectionTitle"]
                    </h1>

                    <p class="lead opacity-75 mb-4 w-75">
                        @Localizer["SelectionSubTitle"]
                    </p>

                    <div class="d-flex align-items-center gap-2">
                        <div class="d-flex">
                            <div class="rounded-circle border border-2 border-white bg-secondary" style="width:30px; height:30px;"></div>
                            <div class="rounded-circle border border-2 border-white bg-dark" style="width:30px; height:30px; margin-left: -10px;"></div>
                            <div class="rounded-circle border border-2 border-white bg-info" style="width:30px; height:30px; margin-left: -10px;"></div>
                        </div>

                        <small class="opacity-75 ms-2">
                            @Localizer["TrustedTourists"]
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 d-flex align-items-start justify-content-center bg-white min-vh-100 pt-5 mt-lg-5">
            <div class="w-100 px-4 px-lg-5" style="max-width: 550px;">

                <h2 class="fw-bold mb-5 text-dark display-6">
                    @Localizer["WhoYouAre"]?
                </h2>

                <form method="post">
                    <button type="submit"
                            name="userType"
                            value="Local"
                            class="btn w-100 text-start p-4 mb-3 rounded-4 d-flex align-items-center bg-white border shadow-sm transition-hover">
                
                        <div class="rounded-3 p-3 me-4 flex-shrink-0 d-flex align-items-center justify-content-center"
                             style="background-color:#669BC0; width: 60px; height: 60px;">
                            <i class="bi bi-wallet2 fs-3 text-white"></i>
                        </div>

                        <div class="text-dark">
                            <h6 class="fw-bold mb-1">@Localizer["LocalUser"]</h6>
                            <p class="small text-muted mb-0">
                                @Localizer["LocalDesc"]
                            </p>
                        </div>
                    </button>

                    <button type="submit"
                            name="userType"
                            value="Tourist"
                            class="btn w-100 text-start p-4 mb-4 rounded-4 d-flex align-items-center bg-white border shadow-sm transition-hover">

                        <div class="rounded-3 p-3 me-4 flex-shrink-0 d-flex align-items-center justify-content-center"
                             style="background-color:#669BC0; width: 60px; height: 60px;">
                            <i class="bi bi-globe-americas fs-3 text-white"></i>
                        </div>

                        <div class="text-dark">
                            <h6 class="fw-bold mb-1">@Localizer["TouristUser"]</h6>
                            <p class="small text-muted mb-0">
                                @Localizer["TouristDesc"]
                            </p>
                        </div>
                    </button>
                </form>

            </div>
        </div>

    </div>
</div>