@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="container-fluid p-0">
    <div class="row g-0 vh-100">
        
        <div class="col-md-6 d-none d-md-flex align-items-end p-5 position-relative" 
             style="background: linear-gradient(rgba(62, 99, 125, 0.2), rgba(62, 99, 125, 0.7)), 
                        url('/img/city.png'); 
                    background-size: cover; 
                    background-position: center;">
            
            <div class="mb-5 pb-4 text-white">
                <h1 class="display-4 fw-bold mb-3 lh-sm">The Kinetic Editorial of Urban Mobility.</h1>
                <p class="lead opacity-75 mb-4 w-75">
                    Discover Saigon's hidden gems through curated bike routes and sustainable travel experiences.
                </p>
                <div class="d-flex align-items-center gap-2">
                    <div class="d-flex">
                        <img src="https://i.pravatar.cc/40?u=1" class="rounded-circle border border-2 border-white shadow-sm" style="width:35px; margin-right: -10px;">
                        <img src="https://i.pravatar.cc/40?u=2" class="rounded-circle border border-2 border-white shadow-sm" style="width:35px; margin-right: -10px;">
                        <img src="https://i.pravatar.cc/40?u=3" class="rounded-circle border border-2 border-white shadow-sm" style="width:35px;">
                    </div>
                    <small class="opacity-75 ms-2">Trusted by 500+ tourists monthly</small>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 d-flex align-items-center justify-content-center bg-light bg-opacity-10">
            <div class="w-100 px-4 px-lg-5" style="max-width: 550px;">
                
                <h2 class="fw-bold mb-5 text-dark display-6">Who you are</h2>

                <form method="post">
                    <button type="submit" name="userType" value="Local" 
                            class="btn btn-outline-secondary w-100 text-start p-4 mb-3 rounded-4 d-flex align-items-center bg-white border-1 shadow-sm border-light-subtle">
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-4 flex-shrink-0">
                            <i class="bi bi-wallet2 fs-3 text-primary"></i>
                        </div>
                        <div class="text-dark">
                            <h6 class="fw-bold mb-1">Local User</h6>
                            <p class="small text-muted mb-0 lh-sm">Integrated with Vietnam's leading digital wallets. Requires Phone OTP verification.</p>
                        </div>
                    </button>

                    <button type="submit" name="userType" value="Tourist" 
                            class="btn btn-outline-secondary w-100 text-start p-4 mb-4 rounded-4 d-flex align-items-center bg-white border-1 shadow-sm border-light-subtle">
                        <div class="bg-info bg-opacity-10 rounded-3 p-3 me-4 flex-shrink-0">
                            <i class="bi bi-globe-americas fs-3 text-info"></i>
                        </div>
                        <div class="text-dark">
                            <h6 class="fw-bold mb-1">Tourist</h6>
                            <p class="small text-muted mb-0 lh-sm">Seamlessly explore with global payment standards. Requires Passport upload.</p>
                        </div>
                    </button>
                </form>

                <div class="text-center mt-3">
                    <p class="text-muted small">
                        Already have an account? <a href="/Account/Login" class="text-primary fw-bold text-decoration-none">Log in</a>
                    </p>
                </div>

                <div class="mt-5 d-flex justify-content-center gap-4 small text-secondary opacity-50 user-select-none">
                    <span>Language</span>
                    <span>Support</span>
                </div>
            </div>
        </div>
    </div>
</div>