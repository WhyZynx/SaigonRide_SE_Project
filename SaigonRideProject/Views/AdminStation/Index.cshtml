@model List<SaigonRideProject.ViewModels.AdminStationViewModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4" style="background-color: #f8f9fa; min-height: 100vh;">

    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: #1a2e5a;">Station Management</h2>
            <nav aria-label="breadcrumb">
            </nav>
        </div>

        <a class="btn btn-primary rounded-3 px-3 py-2 shadow-sm border-0"
               href="/AdminStation/Create"
               style="background: linear-gradient(to right, #548EB7);">
            <i class="bi bi-plus-lg me-2"></i>Add Station
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-primary border-4">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.75rem;">Total Stations</small>
                        <h3 class="fw-bold mb-0 mt-1">@Model.Count()</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-success border-4">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.75rem;">Active Service</small>
                        <h3 class="fw-bold mb-0 mt-1 text-success">@Model.Count(x => x.Status == "Active")</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-danger border-4">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.75rem;">Low Inventory</small>
                        <h3 class="fw-bold mb-0 mt-1 text-danger">@Model.Count(x => x.VehicleCount < 5)</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-3 mb-4 bg-white">
        <div class="row g-3 align-items-center">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="searchBox" class="form-control bg-light border-0"/>
                </div>
            </div>

            <div class="col-md-4">
                <div class="input-group">
                    <span></span>
                    <select id="status" class="form-select bg-light border-0">
                        <option value="">All Statuses</option>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white border-0 pt-4 px-4">
            <h5 class="fw-bold mb-0" style="color: #1a2e5a;">Station List</h5>
        </div>
        <div class="card-body p-0">
            <div id="stationTable">
                @Html.Partial("_StationTable", Model)
            </div>
        </div>
    </div>
</div>

<script src="~/js/admin-station.js"></script>

