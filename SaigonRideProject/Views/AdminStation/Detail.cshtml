@model SaigonRideProject.ViewModels.AdminStationViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">

    <h3 class="mb-4">🔍 Station Detail</h3>

    <div class="card p-4 rounded-4 shadow-sm">

        <p><b>Name:</b> @Model.Name</p>
        <p><b>Address:</b> @Model.Address</p>
        <p><b>Capacity:</b> @Model.Capacity</p>
        <p><b>Inventory:</b> @Model.VehicleCount</p>
        <p><b>Location:</b> @Model.Latitude, @Model.Longitude</p>

    </div>

</div>