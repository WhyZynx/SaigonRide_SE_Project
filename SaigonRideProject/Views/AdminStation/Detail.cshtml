@model SaigonRideProject.ViewModels.AdminStationViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="/AdminStation" class="btn btn-light">← Back</a>
        <h3 class="fw-bold">🔍 Station Detail</h3>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4">

        <div class="row g-4">

            <div class="col-md-6">
                <p><b>Name:</b><br /> @Model.Name</p>
                <p><b>Address:</b><br /> @Model.Address</p>
                <p><b>Capacity:</b><br /> @Model.Capacity</p>
            </div>

            <div class="col-md-6">
                <p><b>Inventory:</b><br /> @Model.VehicleCount</p>
                <p><b>Latitude:</b><br /> @Model.Latitude</p>
                <p><b>Longitude:</b><br /> @Model.Longitude</p>
            </div>

        </div>

        <!-- INVENTORY BAR -->
        @{
            var percent = Model.Capacity == 0 ? 0 : (int)((double)Model.VehicleCount / Model.Capacity * 100);
        }

        <div class="mt-4">
            <label class="fw-semibold">Usage</label>
            <div class="progress" style="height:8px;">
                <div class="progress-bar bg-success" style="width:@percent%"></div>
            </div>
            <small>@Model.VehicleCount / @Model.Capacity</small>
        </div>

    </div>

    <!-- VEHICLE LIST -->
    <ul class="list-group">

        @if (Model.Vehicles != null && Model.Vehicles.Any())
        {
            foreach (var v in Model.Vehicles)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">

                    <!-- LEFT -->
                    <span>
                        @(v.VehicleType == "Bike" ? "🚲" : "🛴")
                        @v.VehicleType - @v.PlateNumber
                    </span>

                    <!-- RIGHT STATUS -->
                    @if (v.Status == "Available")
                    {
                        <span class="badge bg-success">
                            <i class="bi bi-check-circle"></i> Available
                        </span>
                    }
                    else if (v.Status == "InUse")
                    {
                        <span class="badge bg-warning text-dark">
                            <i class="bi bi-lightning"></i> In Use
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            <i class="bi bi-gear"></i> Maintenance
                        </span>
                    }

                </li>
            }
        }
        else
        {
            <li class="list-group-item text-center text-muted">
                No vehicles in this station
            </li>
        }

    </ul>

</div>