@model List<SaigonRideProject.ViewModels.AdminStationViewModel>

<table class="table table-striped table-hover table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Address</th>
            <th>Capacity</th>
            <th>Current</th>
            <th>Lat</th>
            <th>Lng</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Id</td>
                <td>@s.Name</td>
                <td>@s.Address</td>
                <td>@s.Capacity</td>
                <td>@s.VehicleCount</td>
                <td>@s.Latitude</td>
                <td>@s.Longitude</td>

                <td>
                    <span class="badge bg-success">@s.Status</span>
                </td>

                <td class="text-nowrap">
                    <a class="btn btn-sm btn-warning" href="/AdminStation/Edit/@s.Id">Edit</a>
                    <a class="btn btn-sm btn-info" href="/AdminStation/Detail/@s.Id">Detail</a>
                    <a class="btn btn-sm btn-danger" href="/AdminStation/Delete/@s.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>