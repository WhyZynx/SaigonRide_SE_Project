@model List<SaigonRideProject.ViewModels.AdminStationViewModel>

<table class="table table-hover align-middle">

    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>Station</th>
            <th>Capacity</th>
            <th>Inventory</th>
            <th>Location</th>
            <th>Status</th>
            <th class="text-end">Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var s in Model)
        {
            var percent = s.Capacity == 0 ? 0 : (int)((double)s.VehicleCount / s.Capacity * 100);

            <tr>
                <td>@s.Id</td>

                <!-- Name -->
                <td>
                    <div class="fw-semibold">@s.Name</div>
                    <small class="text-muted">@s.Address</small>
                </td>

                <!-- Capacity -->
                <td>@s.Capacity</td>

                <!-- Inventory + progress -->
                <td>
                    <div class="progress" style="height:6px;">
                        <div class="progress-bar bg-success"
                             style="width:@percent%"></div>
                    </div>
                    <small>@s.VehicleCount / @s.Capacity</small>
                </td>

                <!-- Location -->
                <td>
                    <small>@s.Latitude, @s.Longitude</small>
                </td>

                <!-- Status -->
                <td>
                    @if (s.Status == "Active")
                    {
                        <span class="badge bg-success">
                            <i class="bi bi-check-circle"></i> Active
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            <i class="bi bi-x-circle"></i> Inactive
                        </span>
                    }
                </td>

                <!-- Action -->
                <td class="text-end">

                    <a class="btn btn-sm text-warning"
                       href="/AdminStation/Edit/@s.Id"
                       title="Edit">
                        ✏️
                    </a>

                    <a class="btn btn-sm text-info"
                       href="/AdminStation/Detail/@s.Id"
                       title="Detail">
                        🔍
                    </a>

                    <a class="btn btn-sm text-danger"
                       href="/AdminStation/Delete/@s.Id"
                       title="Delete">
                        🗑️
                    </a>

                </td>
            </tr>
        }
    </tbody>

</table>