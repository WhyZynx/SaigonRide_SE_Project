@model SaigonRideProject.ViewModels.AdminStationViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">✏️ Edit Station</h3>
        <a href="/AdminStation" class="btn btn-light">← Back</a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            <form method="post">

                <input type="hidden" asp-for="Id" />

                <div class="row g-4">

                    <!-- LEFT -->
                    <div class="col-md-6">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Station Name</label>
                            <input asp-for="Name" class="form-control rounded-3" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Address</label>
                            <input asp-for="Address" class="form-control rounded-3" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Capacity</label>
                            <input asp-for="Capacity" class="form-control rounded-3" />
                        </div>

                    </div>

                    <!-- RIGHT -->
                    <div class="col-md-6">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Current Vehicles</label>
                            <input asp-for="VehicleCount" class="form-control rounded-3" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Latitude</label>
                            <input asp-for="Latitude" class="form-control rounded-3" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Longitude</label>
                            <input asp-for="Longitude" class="form-control rounded-3" />
                        </div>

                    </div>

                </div>

                <!-- ACTION -->
                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a href="/AdminStation" class="btn btn-light">Cancel</a>
                    <button class="btn btn-primary px-4">Save</button>
                </div>

            </form>

        </div>
    </div>
</div>