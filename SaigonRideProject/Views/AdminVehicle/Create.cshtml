@model SaigonRideProject.ViewModels.AdminVehicleViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">

    <h3 class="fw-bold mb-4">➕ Add Vehicle</h3>

    <div class="card border-0 shadow-sm rounded-4 p-4">

        <form method="post">

            <div class="row g-3">

                <div class="col-md-6">
                    <label class="form-label">Vehicle Type</label>
                    <select class="form-select" name="VehicleType">
                        <option value="Bike">🚲 Bike</option>
                        <option value="E-Scooter">🛴 E-Scooter</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Plate Number</label>
                    <input class="form-control" name="PlateNumber" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Status</label>
                    <select class="form-select" name="Status">
                        <option value="Available">🟢 Available</option>
                        <option value="InUse">🟡 In Use</option>
                        <option value="Maintenance">⚙️ Maintenance</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Price Per Minute</label>
                    <select class="form-select" name="PricePerMinute">
                        <option value="500">500 VND</option>
                        <option value="1500">1500 VND</option>
                    </select>
                </div>

                <div class="col-md-12">
                    <label class="form-label">Station</label>
                    <select class="form-select" name="StationId">
                        @foreach (var s in ViewBag.Stations)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button class="btn btn-success">Create</button>
                <a href="/AdminVehicle" class="btn btn-secondary">Cancel</a>
            </div>

        </form>

    </div>

</div>