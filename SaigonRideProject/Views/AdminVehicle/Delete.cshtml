@model SaigonRideProject.ViewModels.AdminVehicleViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/AdminVehicle" class="btn btn-light rounded-circle shadow-sm border">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h3 class="fw-bold mb-0 text-danger">Confirm Delete</h3>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white text-center p-4">
                <div class="d-flex align-items-center justify-content-center rounded-4 mb-3" style="height:200px; background-color:#fff5f5;">
                    <i class="bi @(Model.VehicleType == "Bike" ? "bi-bicycle" : "bi-scooter") text-danger"
                       style="font-size:8rem; opacity:0.8;"></i>
                </div>
                <h5 class="fw-bold mb-1">@Model.PlateNumber</h5>
                <span class="badge bg-light text-secondary border">@Model.VehicleType</span>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="alert alert-danger d-flex align-items-center gap-3 rounded-3 mb-4">
                    <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                    <div>
                        <strong class="d-block">Warning</strong>
                        Are you sure you want to permanently remove this vehicle from the system?
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-info-circle fs-5" style="color:#1a2e5a;"></i>
                    <span class="fw-semibold fs-6" style="color:#1a2e5a;">Vehicle Information</span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-sm-6">
                        <div class="p-3 border rounded-3 bg-light">
                            <small class="text-muted d-block">Current Status</small>
                            <span class="@(Model.Status == "Available" ? "text-success" : "text-warning")">
                                ● @Model.Status
                            </span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="p-3 border rounded-3 bg-light">
                            <small class="text-muted d-block">Current Station</small>

                            <span>
                                @(!string.IsNullOrEmpty(Model.StationName)
                                    ? Model.StationName
                                    : $"Station ID: {Model.StationId}")
                            </span>
                        </div>
                    </div>
                </div>

                <form method="post" class="mt-auto pt-3">
                    <input type="hidden" name="Id" value="@Model.Id" />
                    
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-danger px-4 py-2 rounded-3 shadow-sm">
                            <i class="bi bi-trash me-2"></i>Delete
                        </button>
                        <a href="/AdminVehicle" class="btn btn-light border px-4 py-2 rounded-3">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>