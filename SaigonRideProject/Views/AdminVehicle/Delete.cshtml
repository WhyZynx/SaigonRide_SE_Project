@model SaigonRideProject.ViewModels.AdminVehicleViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">

    <h3 class="fw-bold text-danger mb-4">⚠️ Delete Vehicle</h3>

    <div class="card border-0 shadow-sm rounded-4 p-4">

        <div class="alert alert-danger">
            Are you sure you want to delete this vehicle?
        </div>

        <ul class="list-group mb-3">
            <li class="list-group-item"><strong>Type:</strong> @Model.VehicleType</li>
            <li class="list-group-item"><strong>Plate:</strong> @Model.PlateNumber</li>
            <li class="list-group-item"><strong>Status:</strong> @Model.Status</li>
        </ul>

        <form method="post">
            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="d-flex gap-2">
                <button class="btn btn-danger">Delete</button>
                <a href="/AdminVehicle" class="btn btn-secondary">Cancel</a>
            </div>
        </form>

    </div>

</div>