@model List<SaigonRideProject.ViewModels.AdminVehicleViewModel>

<table class="table table-hover align-middle">

    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>Type</th>
            <th>Plate</th>
            <th>Status</th>
            <th>Price</th>
            <th>Battery</th>
            <th>Station</th>
            <th class="text-end">Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var v in Model)
        {
            <tr>
                <!-- ID -->
                <td>@v.Id</td>

                <!-- TYPE -->
                <td>
                    @(v.VehicleType == "Bike" ? "🚲 Bike" : "🛴 E-Scooter")
                </td>

                <!-- PLATE -->
                <td class="fw-semibold">@v.PlateNumber</td>

                <!-- STATUS -->
                <td>
                    @if (v.Status == "Available")
                    {
                        <span class="badge bg-success">
                            <i class="bi bi-check-circle"></i> Available
                        </span>
                    }
                    else if (v.Status == "InUse")
                    {
                        <span class="badge bg-warning text-dark">
                            <i class="bi bi-lightning"></i> In Use
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            <i class="bi bi-gear"></i> Maintenance
                        </span>
                    }
            </td>

            <!-- PRICE -->
            <td>@String.Format("{0:N0}", v.PricePerMinute) đ</td>

            <!-- BATTERY -->
            <td style="min-width:120px;">
                <div class="progress" style="height:6px;">
                    <div class="progress-bar
                            @(v.BatteryLevel < 20 ? "bg-danger"
                                                       : v.BatteryLevel < 50 ? "bg-warning"
                                                       : "bg-success")"
                             style="width:@v.BatteryLevel%">
                        </div>
                    </div>
                    <small class="text-muted">@v.BatteryLevel%</small>
                </td>

                <!-- STATION -->
                <td>
                    <div>@v.StationName</div>
                    <small class="text-muted">ID: @v.StationId</small>
                </td>

                <!-- ACTION -->
                <td class="text-nowrap text-end">

                    <!-- Edit -->
                    <a href="/AdminVehicle/Edit/@v.Id"
                       class="text-decoration-none me-2"
                       title="Edit">
                        ✏️
                    </a>

                    <!-- Detail -->
                    <a href="/AdminVehicle/Detail/@v.Id"
                         class="text-decoration-none me-2"
                         title="View">
                        🔍
                    </a>


                    <!-- Delete -->
                    <a href="/AdminVehicle/Delete/@v.Id"
                       class="text-decoration-none text-danger"
                       title="Delete">
                        🗑️
                    </a>

                </td>
            </tr>
        }
    </tbody>

</table>