@model List<SaigonRideProject.ViewModels.AdminVehicleViewModel>

<table class="table table-hover align-middle">

    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>Type</th>
            <th>Plate</th>
            <th>Status</th>
            <th>Price</th>
            <th>Battery</th>
            <th>Station</th>
            <th class="text-end">Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var v in Model)
        {
            <tr>
                <td>@v.Id</td>

                <td>
                    @if (v.VehicleType == "Bike")
                    {
                        <span>🚲 Bike</span>
                    }
                    else
                    {
                        <span>🛴 E-Scooter</span>
                    }
                </td>

                <td class="fw-semibold">@v.PlateNumber</td>

                <td>
                    @if (v.Status == "Available")
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else if (v.Status == "InUse")
                    {
                        <span class="badge bg-warning text-dark">In Use</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Maintenance</span>
                    }
                </td>

                <td>@v.PricePerMinute đ</td>

                <td>
                    <div class="progress" style="height:6px;">
                        <div class="progress-bar bg-success"
                             style="width:@v.BatteryLevel%"></div>
                    </div>
                    <small>@v.BatteryLevel%</small>
                </td>

                <td>
                    <div>@v.StationName</div>
                    <small class="text-muted">ID: @v.StationId</small>
                </td>

                <td class="text-end">
                    <a class="btn btn-sm btn-outline-warning"
                       href="/AdminVehicle/Edit/@v.Id">
                        <i class="bi bi-pencil"></i>
                    </a>

                    <a class="btn btn-sm btn-outline-info"
                       href="/AdminVehicle/Detail/@v.Id">
                        <i class="bi bi-eye"></i>
                    </a>

                    <a class="btn btn-sm btn-outline-danger"
                       href="/AdminVehicle/Delete/@v.Id">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
        }
    </tbody>

</table>