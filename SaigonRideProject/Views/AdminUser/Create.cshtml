@model SaigonRideProject.Models.User

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4" style="background-color: #f0f7ff; min-height: 100vh;">
    <div class="mb-5">
        <h1 class="fw-bold" style="color: #1a2e5a; font-size: 2.5rem;">Create New User</h1>
    </div>

    <form method="post">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm rounded-4 p-4" style="background-color: #e3f0ff;">
                    
                    <div class="mb-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="p-2 bg-white rounded-3 shadow-sm">
                                <i class="bi bi-person-badge-fill text-primary"></i>
                            </div>
                            <h5 class="mb-0 fw-bold" style="color: #1a2e5a;">Account Identity</h5>
                        </div>
                        
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="small fw-bold text-muted mb-1 text-uppercase">Full Name</label>
                                <input name="FullName" class="form-control border-0 py-2 shadow-sm rounded-3" required />
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold text-muted mb-1 text-uppercase">Email Address</label>
                                <input name="Email" type="email" class="form-control border-0 py-2 shadow-sm rounded-3"required />
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold text-muted mb-1 text-uppercase">Initial Password</label>
                                <input name="password" type="password" class="form-control border-0 py-2 shadow-sm rounded-3"required />
                            </div>
                        </div>
                    </div>

                    <hr class="opacity-10 my-4">

                    <div class="mb-2">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="p-2 bg-white rounded-3 shadow-sm">
                                <i class="bi bi-person-gear text-primary"></i>
                            </div>
                            <h5 class="mb-0 fw-bold" style="color: #1a2e5a;">Roles & Configuration</h5>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="small fw-bold text-muted mb-1 text-uppercase">User Type</label>
                                <select name="UserType" class="form-select border-0 py-2 shadow-sm rounded-3">
                                    <option value="Local">Local</option>
                                    <option value="Tourist">Tourist</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold text-muted mb-1 text-uppercase">Initial Balance (VNĐ)</label>
                                <div class="input-group shadow-sm rounded-3 overflow-hidden">
                                    <span class="input-group-text border-0 bg-white"><i class="bi bi-wallet2 text-muted"></i></span>
                                    <input name="Balance" class="form-control border-0 py-2" value="0" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-3">
                        <button type="submit" class="btn btn-primary px-5 py-2 shadow-sm border-0 rounded-3"
                                style="background: linear-gradient(to right, #1a2e5a, #2a4a8e);">
                            <i class="bi bi-person-plus-fill me-2"></i>Create User
                        </button>
                        <a href="/AdminUser" class="btn btn-light px-4 py-2 rounded-3 border-0 shadow-sm"
                               style="background-color: #cbdbe6; color: #1a2e5a;">
                            Cancel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

