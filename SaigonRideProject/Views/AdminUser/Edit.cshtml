@model SaigonRideProject.ViewModels.UserViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4" style="background-color: #f0f7ff; min-height: 100vh;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/AdminUser" class="btn btn-white rounded-circle shadow-sm border">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h2 class="fw-bold mb-0" style="color: #1a2e5a;">Edit User Profile</h2>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4" style="background-color: #e3f0ff;">
                <form method="post">
                    <input type="hidden" name="Id" value="@Model.Id" />

                    <div class="mb-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="p-2 bg-white rounded-3 shadow-sm">
                                <i class="bi bi-person-lines-fill text-primary"></i>
                            </div>
                            <h5 class="mb-0 fw-bold" style="color: #1a2e5a;">Identity Details</h5>
                        </div>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="small fw-bold text-muted mb-1 text-uppercase">Full Name</label>
                                <input name="FullName" value="@Model.FullName" class="form-control border-0 py-2 shadow-sm rounded-3" required />
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold text-muted mb-1 text-uppercase">Email (ReadOnly)</label>
                                <input value="@Model.Email" class="form-control border-0 py-2 shadow-sm rounded-3 bg-white bg-opacity-50" disabled />
                            </div>
                            <div class="col-md-12">
                                <label class="small fw-bold text-muted mb-1 text-uppercase">Classification</label>
                                <select asp-for="UserType" class="form-select border-0 py-2 shadow-sm rounded-3">
                                    <option value="Local">Local</option>
                                    <option value="Tourist">Tourist</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <hr class="opacity-10 my-4">

                    <div class="mb-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="p-2 bg-white rounded-3 shadow-sm">
                                <i class="bi bi-shield-lock-fill text-primary"></i>
                            </div>
                            <h5 class="mb-0 fw-bold" style="color: #1a2e5a;">Status & Permissions</h5>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-check p-3 bg-white rounded-4 shadow-sm border-0 d-flex align-items-center">
                                    <div class="flex-grow-1">
                                        <label class="form-check-label fw-bold d-block" style="color: #1a2e5a;">Verified Account</label>
                                    </div>
                                    <input name="IsVerified" type="checkbox" class="form-check-input fs-5" 
                                           value="true" @(Model.IsVerified ? "checked" : "") style="margin-right: 0.5rem;" />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-check p-3 bg-white rounded-4 shadow-sm border-0 d-flex align-items-center">
                                    <div class="flex-grow-1">
                                        <label class="form-check-label fw-bold d-block text-danger">Lock Account</label>
                                    </div>
                                    <input name="IsLocked" type="checkbox" class="form-check-input fs-5" 
                                           value="true" @(Model.IsLocked ? "checked" : "") style="margin-right: 0.5rem;" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-3">
                        <button type="submit" class="btn btn-primary px-5 py-2 shadow-sm border-0 rounded-3" 
                                style="background: linear-gradient(to right, #1a2e5a, #2a4a8e);">
                            Save Changes
                        </button>
                        <a href="/AdminUser" class="btn btn-light px-4 py-2 rounded-3 border-0 shadow-sm" 
                           style="background-color: #cbdbe6; color: #1a2e5a;">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="p-4 text-center" style="background: linear-gradient(135deg, #1a2e5a, #2a4a8e); color: white;">
                    <div class="bg-white mx-auto rounded-circle d-flex align-items-center justify-content-center fw-bold text-primary mb-3 shadow" 
                         style="width: 80px; height: 80px; font-size: 2rem;">
                        @Model.FullName.Substring(0,1).ToUpper()
                    </div>
                    <h5 class="fw-bold mb-0">@Model.FullName</h5>
                    <small class="opacity-75">Member ID: @Model.Id</small>
                </div>
                <div class="card-body bg-white p-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Current Status:</span>
                        @if(Model.IsLocked){
                            <span class="badge bg-danger-subtle text-danger rounded-pill px-3">Suspended</span>
                        } else {
                            <span class="badge bg-success-subtle text-success rounded-pill px-3">Active</span>
                        }
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small">Verification:</span>
                         @if(Model.IsVerified){
                            <span class="badge bg-primary-subtle text-primary rounded-pill px-3">Verified</span>
                        } else {
                            <span class="badge bg-light text-dark border rounded-pill px-3">Unverified</span>
                        }
                    </div>
                    <hr>
                    <div class="alert bg-light border-0 small mb-0">
                        <i class="bi bi-info-circle me-1 text-primary"></i>
                        Locking an account will immediately revoke a user's access to the application.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

