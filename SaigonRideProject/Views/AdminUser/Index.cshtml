@model List<SaigonRideProject.ViewModels.UserViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="fw-bold mb-1">👥 User Management</h3>
            <p class="text-muted mb-0">Manage all system users</p>
        </div>

        <a class="btn btn-success px-3" href="/AdminUser/Create">
            + Add User
        </a>

    </div>

    <!-- STATS -->
    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3">
                <div class="text-muted small">Total Users</div>
                <div class="fs-4 fw-bold">@Model.Count</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3">
                <div class="text-muted small">Local Users</div>
                <div class="fs-4 fw-bold text-primary">
                    @Model.Count(x => x.UserType == "Local")
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3">
                <div class="text-muted small">Tourists</div>
                <div class="fs-4 fw-bold text-success">
                    @Model.Count(x => x.UserType == "Tourist")
                </div>
            </div>
        </div>

    </div>

    <!-- FILTER BAR -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">

        <div class="card-body">

            <div class="row g-3">

                <!-- SEARCH -->
                <div class="col-md-6">
                    <input id="searchBox"
                           class="form-control"
                           placeholder="🔍 Search name or email..." />
                </div>

                <!-- TYPE -->
                <div class="col-md-3">
                    <select id="userType" class="form-select">
                        <option value="">All Types</option>
                        <option value="Local">Local</option>
                        <option value="Tourist">Tourist</option>
                    </select>
                </div>

                <!-- STATUS -->
                <div class="col-md-3">
                    <select id="status" class="form-select">
                        <option value="">All Status</option>
                        <option value="Active">Active</option>
                        <option value="Suspended">Suspended</option>
                    </select>
                </div>

            </div>

        </div>

    </div>

    <!-- TABLE -->
    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-0">

            <div id="userTable">
                @Html.Partial("_UserTable", Model)
            </div>

        </div>

    </div>

</div>

<!-- SCRIPT -->
<script src="~/js/admin-user.js"></script>