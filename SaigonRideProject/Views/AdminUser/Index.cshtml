@model List<SaigonRideProject.ViewModels.UserViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4" style="background-color: #f8f9fa; min-height: 100vh;">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-1" style="color: #1a2e5a;">User Management</h2>
        </div>

        <a href="/AdminUser/Create" class="btn btn-primary px-4 py-2 rounded-3 shadow-sm border-0 d-flex align-items-center gap-2"
               style="background: linear-gradient(to right, #548EB7); transition: all 0.3s ease;">
            <i class="bi bi-person-plus-fill"></i>
            <span>Add New User</span>
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-primary border-4 hover-lift">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.7rem;">Total Users</small>
                        <h3 class="fw-bold mb-0 mt-1" style="color: #1a2e5a;">@Model.Count</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-info border-4 hover-lift">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.7rem;">Local Residents</small>
                        <h3 class="fw-bold mb-0 mt-1" style="color: #0dcaf0;">@Model.Count(x => x.UserType == "Local")</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-success border-4 hover-lift">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.7rem;">Global Tourists</small>
                        <h3 class="fw-bold mb-0 mt-1 text-success">@Model.Count(x => x.UserType == "Tourist")</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-12 col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search text-muted"></i></span>
                        <input id="searchBox" class="form-control bg-light border-0 shadow-none"/>
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold text-muted text-nowrap">TYPE:</label>
                        <select id="userType" class="form-select bg-light border-0 shadow-none rounded-3 small">
                            <option value="">All Types</option>
                            <option value="Local">Local</option>
                            <option value="Tourist">Tourist</option>
                        </select>
                    </div>
                </div>

                <div class="col-6 col-md-4">
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold text-muted text-nowrap">STATUS:</label>
                        <select id="status" class="form-select bg-light border-0 shadow-none rounded-3 small">
                            <option value="">All Status</option>
                            <option value="Active">Active</option>
                            <option value="Suspended">Suspended</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center border-bottom">
            <h5 class="fw-bold mb-0" style="color: #1a2e5a;">User Registry</h5>
        </div>
        <div class="card-body p-0">
            <div id="userTable">
                @Html.Partial("_UserTable", Model)
            </div>
        </div>
    </div>
</div>

<script src="~/js/admin-user.js"></script>
