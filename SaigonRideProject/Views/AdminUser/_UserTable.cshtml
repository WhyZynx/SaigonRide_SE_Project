@model List<SaigonRideProject.ViewModels.UserViewModel>

<table class="table table-hover table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>User Type</th>
            <th>Contact</th>
            <th>Verification</th>
            <th>Status</th>
            <th>Balance</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Id</td>

                <td>
                    <b>@u.FullName</b><br />
                    <small class="text-muted">@u.Email</small>
                </td>

                <td>
                    @if (u.UserType == "Tourist")
                    {
                        <span class="badge bg-info">Tourist</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Local</span>
                    }
                </td>

                <td>
                    @u.Email
                </td>

                <!-- VERIFICATION -->
                <td>
                    @if (u.PassportStatus == "Approved")
                    {
                        <span class="badge bg-success">Passport Verified</span>
                    }
                    else if (u.PassportStatus == "Pending")
                    {
                        <span class="badge bg-warning text-dark">Pending</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Not Submitted</span>
                    }
                </td>

                <!-- STATUS -->
                <td>
                    @if (u.IsLocked)
                    {
                        <span class="badge bg-danger">Suspended</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Active</span>
                    }
                </td>

                <!-- BALANCE -->
                <td>
                    <span class="text-success fw-bold">
                        @u.Balance.ToString("N0")
                    </span>
                </td>

                <!-- ACTION -->
                <td class="text-nowrap">

                    <a class="btn btn-sm btn-info"
                           href="/AdminUser/Detail/@u.Id">
                        Detail
                    </a>

                    <a class="btn btn-sm btn-warning"
                           href="/AdminUser/Edit/@u.Id">
                        Edit
                    </a>

                    @if (u.IsLocked)
                    {
                        <a class="btn btn-sm btn-success"
                               href="/AdminUser/Unlock/@u.Id">
                            Unlock
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-danger"
                               href="/AdminUser/Delete/@u.Id"
                               onclick="return confirm('Lock this user?')">
                            Lock
                        </a>
                    }

                    @if (u.PassportStatus == "Pending")
                    {
                        <a class="btn btn-sm btn-primary"
                               href="/AdminUser/Approve/@u.Id">
                            Approve
                        </a>
                    }

                </td>
            </tr>
        }
    </tbody>
</table>