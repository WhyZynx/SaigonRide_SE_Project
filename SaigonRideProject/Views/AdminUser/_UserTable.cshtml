@model List<SaigonRideProject.ViewModels.UserViewModel>

<table class="table table-hover align-middle border">

    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>User</th>
            <th>Type</th>
            <th>Contact</th>
            <th>Verification</th>
            <th>Status</th>
            <th>Balance</th>
            <th class="text-end">Action</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var u in Model)
        {
            <tr>

                <!-- ID -->
                <td class="text-muted">@u.Id</td>

                <!-- USER -->
                <td>
                    <div class="fw-semibold">@u.FullName</div>
                    <small class="text-muted">✉️ @u.Email</small>
                </td>

                <!-- TYPE -->
                <td>
                    @if (u.UserType == "Tourist")
                    {
                        <span class="badge bg-info">🌍 Tourist</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">🏠 Local</span>
                    }
                </td>

                <!-- CONTACT -->
                <td>@u.Email</td>

                <!-- VERIFICATION -->
                <td>
                    @if (u.PassportStatus == "Approved")
                    {
                        <span class="badge bg-success">
                            ✔️ Verified
                        </span>
                    }
                    else if (u.PassportStatus == "Pending")
                    {
                        <span class="badge bg-warning text-dark">
                            ⏳ Pending
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            ❌ Not Submitted
                        </span>
                    }
                </td>

                <!-- STATUS -->
                <td>
                    @if (u.IsLocked)
                    {
                        <span class="badge bg-danger">
                            🔒 Suspended
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-success">
                            🟢 Active
                        </span>
                    }
                </td>

                <!-- BALANCE -->
                <td>
                    <span class="fw-bold text-success">
                        @String.Format("{0:N0} đ", u.Balance)
                    </span>
                </td>

                <!-- ACTION -->
                <td class="text-end">

                    <!-- DETAIL -->
                    <a class="btn btn-sm btn-light rounded-circle"
                       href="/AdminUser/Detail/@u.Id"
                       title="Detail">
                        🔍
                    </a>

                    <!-- EDIT -->
                    <a class="btn btn-sm btn-light rounded-circle"
                       href="/AdminUser/Edit/@u.Id"
                       title="Edit">
                        ✏️
                    </a>

                    <!-- LOCK / UNLOCK -->
                    @if (u.IsLocked)
                    {
                        <a class="btn btn-sm btn-light rounded-circle text-success"
                           href="/AdminUser/Unlock/@u.Id"
                           title="Unlock">
                            🔓
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-light rounded-circle text-danger"
                           href="/AdminUser/Delete/@u.Id"
                           onclick="return confirm('Lock this user?')"
                           title="Lock">
                            🔒
                        </a>
                    }

                    <!-- APPROVE -->
                    @if (u.PassportStatus == "Pending")
                    {
                        <a class="btn btn-sm btn-light rounded-circle text-primary"
                           href="/AdminUser/Approve/@u.Id"
                           title="Approve">
                            ✔️
                        </a>
                    }

                </td>

            </tr>
        }

    </tbody>

</table>