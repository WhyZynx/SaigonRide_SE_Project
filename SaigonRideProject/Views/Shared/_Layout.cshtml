<!DOCTYPE html>
<html>
<head>
    <title>SaigonRide</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
</head>

<body>

    @if (Context.Session.GetString("UserId") != null)
    {
        <nav class="navbar navbar-dark bg-dark px-3">
            <a class="navbar-brand" href="/UserDashboard">SaigonRide</a>

            <div>
                <a class="btn btn-outline-light" href="/Rental/StationList">Stations</a>
                <a class="btn btn-outline-light" href="/Rental/Current">My Trip</a>
                <a class="btn btn-outline-light" href="/Rental/History">History</a>
                <a class="btn btn-danger" href="/Account/Logout">Logout</a>
            </div>
        </nav>
    }
    else
    {
        <nav class="navbar navbar-light bg-light px-3">
            <a class="navbar-brand" href="/">SaigonRide</a>

            <div>
                <a class="btn btn-primary" href="/Account/Login">Login</a>
            </div>
        </nav>
    }

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>