@using SaigonRideProject.Data
@using Microsoft.Extensions.Localization
@inject AppDbContext _context
@using SaigonRideProject.Resources

@inject IStringLocalizerFactory LocalizerFactory
@{
    var Localizer = LocalizerFactory.Create("SharedResource", "SaigonRideProject");

    var userId = Context.Session.GetInt32("UserId");

    var user = userId != null
        ? _context.Users.FirstOrDefault(x => x.Id == userId)
        : null;

    var identityNumber = user?.IdentityNumber;

    var hasTrip = ViewBag.HasActiveRental != null && (bool)ViewBag.HasActiveRental;
    var currentPath = Context.Request.Path.ToString();
}

<!DOCTYPE html>
<html>
<head>
    <title>SaigonRide</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    
    <style>
        .custom-nav .nav-link {
            color: #6c757d !important;
            font-weight: 500;
            transition: all 0.25s ease-in-out;
            position: relative;
            border-radius: 8px;
        }

        .custom-nav .nav-link:hover {
            color: #5E96BD !important;
            background-color: rgba(94, 150, 189, 0.08);
        }

        .custom-nav .nav-link.active {
            color: #075985 !important;
            font-weight: 700 !important;
        }

        .custom-nav .nav-link.active::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 15%;
            width: 70%;
            height: 3px;
            background-color: #5E96BD;
            border-radius: 2px;
        }
    </style>
</head>

<body>

    @if (identityNumber != null)
    {
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top py-3" style="min-height: 72px;">
            <div class="container-fluid px-4 px-lg-4">

                <a class="navbar-brand m-0 p-0 position-relative" href="" style="width: 180px; height: 40px;">
                    <img src="/img/logo.png" alt="SaigonRide"
                         class="position-absolute top-50 translate-middle-y"
                         style="width: 180px; height: auto; z-index: 1050; left: 0;">
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navContent">
                    <div class="navbar-nav mx-auto gap-2 gap-lg-4 mt-3 mt-lg-0 custom-nav">
                        <a class="nav-link d-flex align-items-center gap-2 px-3 @(currentPath == "/User/UserDashboard" ? "active" : "")"
                               href="/User/UserDashboard">
                            <i class="bi bi-house-door"></i> @Localizer["Homepage"]
                        </a>

                        @if (ViewBag.HasActiveRental == true && ViewBag.ActiveRentalId != null)
                        {
                            var currentRentalPath = "/Rental/Current/" + ViewBag.ActiveRentalId;
                            <a class="nav-link d-flex align-items-center gap-2 px-3 @(currentPath.StartsWith("/Rental/Current") ? "active" : "")"
                                   href="@currentRentalPath">
                                <i class="bi bi-bicycle"></i> @Localizer["CurrentlyRenting"]
                            </a>
                        }

                        <a class="nav-link d-flex align-items-center gap-2 px-3 @(currentPath == "/Rental/History" ? "active" : "")"
                               href="/Rental/History">
                            <i class="bi bi-clock-history"></i> @Localizer["History"]
                        </a>

                        <a class="nav-link d-flex align-items-center gap-2 px-3 @(currentPath == "/User/Transactions" ? "active" : "")"
                               href="/User/Transactions">
                            <i class="bi bi-wallet2"></i> @Localizer["Transactions"]
                        </a>

                        <div class="nav-item dropdown custom-nav">
                            <a class="nav-link d-flex align-items-center gap-2 px-3 dropdown-toggle border-0"
                                   href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-translate"></i> <span>@Localizer["Language"]</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2 py-2"
                                           href="/Language/SetLanguage?culture=vi-VN&returnUrl=@Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString)">
                                        <span class="fi fi-vn"></span> Tiếng Việt
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2 py-2"
                                           href="/Language/SetLanguage?culture=en-US&returnUrl=@Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString)">
                                        <span class="fi fi-us"></span> English
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-2 mt-3 mt-lg-0 pb-3 pb-lg-0">
                        @if (user != null)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <div class="text-end d-none d-sm-block me-1">
                                    <div class="fw-bold lh-1 text-dark mb-2" style="font-size: 0.85rem;">@user.FullName</div>
                                    <div class="text-primary fw-medium lh-1" style="font-size: 0.75rem;">
                                        @user.Balance.ToString("N0") <span style="font-size: 0.65rem;">VND</span>
                                    </div>
                                </div>

                                <a href="/User/Profile" class="text-decoration-none">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center bg-light text-secondary border shadow-sm"
                                         style="width: 38px; height: 38px;">
                                        <i class="bi bi-person-fill fs-5"></i>
                                    </div>
                                </a>
                            </div>
                        }

                        <a class="btn btn-link text-danger p-0" asp-controller="Account" asp-action="Logout" title="Logout">
                            <div class="rounded-circle d-flex align-items-center justify-content-center bg-danger bg-opacity-10"
                                 style="width: 38px; height: 38px;">
                                <i class="bi bi-box-arrow-right fs-5"></i>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    }

    else
    {
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top py-3" style="min-height: 72px;">
            <div class="container-fluid px-4 px-lg-4 position-relative">
            
                <a class="navbar-brand m-0 p-0" href="/" style="width: 180px;">
                    <img src="/img/logo.png" alt="SaigonRide"
                         class="position-absolute top-50 translate-middle-y"
                         style="width: 180px; height: auto; z-index: 1050;">
                </a>

                <div class="ms-auto d-flex align-items-center gap-4">
                
                    <div class="d-flex align-items-center gap-3">
                        <a class="text-decoration-none fw-bold small" href="/Account/Login" style="color:#075985;">Login</a>
                    
                        <a class="btn rounded-pill px-4 py-2 fw-bold shadow-sm text-white" href="/Account/Register" style="background-color:#5E96BD;">
                            Sign Up
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    }

    <div class="container">
        @RenderBody()
    </div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>
