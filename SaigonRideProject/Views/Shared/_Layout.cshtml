<!DOCTYPE html>
<html>
<head>
    <title>SaigonRide</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
</head>

<body>

    @if (Context.Session.GetString("UserId") != null)
    {
        var balance = Context.Session.GetString("Balance");

        <nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
            <div class="container-fluid">

                <a class="navbar-brand" href="/Home/UserDashboard">
                    SaigonRide 🚲
                </a>

                <div class="d-flex align-items-center">

                    @if (balance != null)
                    {
                        <span class="me-3">
                            💰 <strong>@balance VND</strong>
                        </span>
                    }

                    <a href="/Home/UserDashboard" class="btn btn-outline-primary me-2">
                        Home
                    </a>

                    <a href="/Account/Logout" class="btn btn-outline-danger">
                        Logout
                    </a>

                </div>
            </div>
        </nav>
    }
    else
    {
        <nav class="navbar navbar-light bg-light px-3">
            <a class="navbar-brand" href="/">SaigonRide</a>

            <div>
                <a class="btn btn-primary" href="/Account/Login">Login</a>
            </div>
        </nav>
    }

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>