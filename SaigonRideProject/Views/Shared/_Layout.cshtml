@using SaigonRideProject.Data
@inject AppDbContext _context

@{
    var userId = Context.Session.GetInt32("UserId");
    var user = _context.Users.FirstOrDefault(x => x.Id == userId);
}
<!DOCTYPE html>
<html>
<head>
    <title>SaigonRide</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
</head>

<body>

    @if (userId != null)
    {
        <nav class="navbar navbar-dark bg-dark px-3">

            <a class="navbar-brand" href="/Home/Index">
                🚲 SaigonRide
            </a>

            <div class="d-flex align-items-center gap-3">

                <a class="btn btn-outline-light btn-sm" href="/Home/Index">
                    Home
                </a>

                <a class="btn btn-outline-light btn-sm" href="/Rental/History">
                    History
                </a>

                <a class="btn btn-outline-light btn-sm" href="/Rental/Current">
                    My Trip
                </a>

                @if (user != null)
                {
                    <span class="text-white">
                        💰 @user.Balance.ToString("N0") VND
                    </span>

                    <span class="badge bg-info">
                        @user.FullName
                    </span>
                }

            </div>

        </nav>
    }
    else
    {
        <nav class="navbar navbar-light bg-light px-3">
            <a class="navbar-brand" href="/">SaigonRide</a>

            <div>
                <a class="btn btn-primary" href="/Account/Login">Login</a>
            </div>
        </nav>
    }

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>
