@using SaigonRideProject.Data
@inject AppDbContext _context
<!DOCTYPE html>
<html>
<head>
    <title>SaigonRide</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <style>
            .nav-link-custom {
                color: #64748b;
                font-size: 0.9rem;
                text-decoration: none;
                transition: color 0.2s;
            }

                .nav-link-custom:hover {
                    color: #075985;
                }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top py-3" style="min-height: 74px;">
        <div class="container-fluid px-4 px-lg-4 position-relative">
            
            <a class="navbar-brand m-0 p-0" href="/" style="width: 180px;">
                <img src="/img/logo.png" alt="SaigonRide"
                     class="position-absolute top-50 translate-middle-y"
                     style="width: 180px; height: auto; z-index: 1050;">
            </a>

            <div class="ms-auto d-flex align-items-center gap-4">
                
                <div class="d-flex align-items-center gap-3">
                    <a href="#" class="text-decoration-none text-secondary small">Language</a>
                    <a href="#" class="text-decoration-none text-secondary small">Support</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>