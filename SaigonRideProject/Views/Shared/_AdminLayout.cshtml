<!DOCTYPE html>
<html>
<head>
    <title>Admin Panel</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="d-flex">

        <div class="bg-dark text-white p-3 vh-100" style="width:250px;">

            <h5 class="text-center mb-4 fw-bold">SaigonRide</h5>

            <ul class="nav nav-pills flex-column">

                <li class="nav-item">
                    <a href="/Admin/Dashboard" class="nav-link text-white">Dashboard</a>
                </li>

                <li>
                    <a href="/AdminVehicle/Index" class="nav-link text-white">Vehicle</a>
                </li>

                <li>
                    <a href="/AdminStation/Index" class="nav-link text-white">Station</a>
                </li>

                <li>
                    <a href="/AdminUser/Index" class="nav-link text-white">User</a>
                </li>

                <li>
                    <a href="/AdminTransaction/Index" class="nav-link text-white">Transaction</a>
                </li>

                <li>
                    <a href="/AdminReport/Index" class="nav-link text-white">Report</a>
                </li>

            </ul>

            <div class="mt-auto">
                <a href="/Account/Logout" class="btn btn-outline-light w-100 mt-4">Logout</a>
            </div>

        </div>

        <div class="flex-grow-1 p-4">

            <div class="container-fluid">
                @RenderBody()
            </div>

        </div>

    </div>

</body>
</html>