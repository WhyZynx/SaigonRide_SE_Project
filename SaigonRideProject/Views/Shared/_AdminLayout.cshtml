<!DOCTYPE html>
<html>
<head>
    <title>Admin Panel</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
        #sidebar {
            width: 260px;
            transform: translateX(-100%);
            transition: all 0.3s ease;
            z-index: 1050;
        }

            #sidebar.show {
                transform: translateX(0);
            }

        #overlay {
            display: none;
            z-index: 1040;
        }

            #overlay.show {
                display: block;
            }
    </style>
</head>

<body class="bg-light">

    <!-- TOPBAR -->
    <nav class="navbar navbar-light bg-white border-bottom px-4 sticky-top">
        <div class="d-flex align-items-center gap-3">

            <button class="btn btn-light" onclick="toggleSidebar()">
                <i class="bi bi-list"></i>
            </button>

            <span class="fw-bold fs-4">SaigonRide</span>
        </div>

        <div class="flex-grow-1 mx-4">
            <input class="form-control"
                   placeholder="Search transactions, stations, users...">
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="text-end">
                <div class="fw-semibold">Admin</div>
                <small class="text-muted">Super Admin</small>
            </div>

            <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center"
                 style="width:40px;height:40px;">
                AD
            </div>
        </div>
    </nav>

    <!-- SIDEBAR -->
    <div id="sidebar" class="bg-primary text-white position-fixed top-0 start-0 vh-100 p-3">

        <h6 class="text-uppercase text-info mb-4">Management</h6>

        <a href="/Admin/Dashboard" class="d-block text-white mb-3">
            <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </a>

        <a href="/AdminVehicle/Index" class="d-block text-white mb-3">
            <i class="bi bi-bicycle me-2"></i> Vehicle
        </a>

        <a href="/AdminStation/Index" class="d-block text-white mb-3">
            <i class="bi bi-geo-alt me-2"></i> Station
        </a>

        <a href="/AdminUser/Index" class="d-block text-white mb-3">
            <i class="bi bi-people me-2"></i> User
        </a>

        <a href="/AdminTransaction/Index" class="d-block text-white mb-3">
            <i class="bi bi-currency-dollar me-2"></i> Transaction
        </a>

        <a href="/AdminReport/Index" class="d-block text-white mb-3">
            <i class="bi bi-bar-chart me-2"></i> Report
        </a>

        <hr class="border-light">

        <a href="/Account/Logout" class="d-block text-white">
            <i class="bi bi-box-arrow-right me-2"></i> Logout
        </a>

    </div>

    <!-- OVERLAY -->
    <div id="overlay" class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-50"
         onclick="toggleSidebar()"></div>

    <!-- MAIN CONTENT -->
    <div class="container-fluid p-4">
        @RenderBody()
    </div>

    <!-- SCRIPT -->
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');

            sidebar.classList.toggle('show');
            overlay.classList.toggle('show');
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === "Escape") {
                document.getElementById('sidebar').classList.remove('show');
                document.getElementById('overlay').classList.remove('show');
            }
        });
    </script>

</body>
</html>