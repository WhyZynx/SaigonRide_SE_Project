<!DOCTYPE html>
<html>
<head>
    <title>Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
            body {
                margin: 0;
                font-family: Arial;
            }

            .sidebar {
                width: 240px;
                height: 100vh;
                position: fixed;
                background: #1e1e2f;
                color: white;
                padding-top: 20px;
            }

                .sidebar a {
                    display: block;
                    color: white;
                    padding: 12px 20px;
                    text-decoration: none;
                }

                    .sidebar a:hover {
                        background: #343a40;
                    }

            .content {
                margin-left: 240px;
                padding: 20px;
            }
    </style>
</head>

<body>

    <div class="sidebar">
        <h4 class="text-center">SaigonRide Admin</h4>

        <a href="/Admin/Dashboard">Dashboard</a>
        <a href="/AdminVehicle/Index">Vehicle Management</a>
        <a href="/AdminStation/Index">Station Management</a>
        <a href="/AdminUser/Index">User Management</a>
        <a href="/AdminTransaction/Index">Transactions</a>
        <a href="/AdminReport/Index">Reports</a>
        <a href="/Admin/Settings">Settings</a>
        <a href="/Account/Logout">Logout</a>
    </div>

    <div class="content container-fluid py-3">
        @RenderBody()
    </div>

</body>
</html>