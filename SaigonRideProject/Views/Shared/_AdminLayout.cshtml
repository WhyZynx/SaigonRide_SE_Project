<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SaigonRide Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <!-- Top Bar -->
    <header class="bg-white border-bottom sticky-top" style="height:64px; z-index:1050;">
        <div class="h-100 d-flex align-items-center px-4 justify-content-between">

            <!-- Left: Toggle + Logo -->
            <div class="d-flex align-items-center gap-3">
                <button onclick="toggleSidebar()" class="btn btn-light rounded-3 p-2 lh-1">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <span class="fw-bold fs-4 text-dark">SaigonRide</span>
            </div>

            <!-- Search -->
            <div class="flex-grow-1 mx-5" style="max-width:520px;">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 rounded-start-3">
                        <i class="bi bi-search text-secondary"></i>
                    </span>
                    <input type="text" class="form-control bg-light border-start-0 rounded-end-3"
                        placeholder="Search transactions, stations, users...">
                </div>
            </div>

            <!-- Right: Admin Info -->
            <div class="d-flex align-items-center gap-3 ps-4 border-start">
                <div class="text-end">
                    <div class="fw-semibold small">Admin</div>
                    <div class="text-muted" style="font-size:0.75rem;">Super Admin</div>
                </div>
                <div class="bg-danger text-white rounded-3 d-flex align-items-center justify-content-center fw-bold"
                    style="width:36px;height:36px;">AD</div>
            </div>

        </div>
    </header>

    <!-- Offcanvas Sidebar (mobile only) -->
    <div class="offcanvas offcanvas-start text-white d-md-none"
        style="width:270px; background-color:#65869D;"
        tabindex="-1" id="mobileSidebar">
        <div class="offcanvas-header">
            <span class="fw-bold fs-5 text-white">SaigonRide</span>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body pt-0">
            <p class="text-uppercase fw-semibold mb-3 ps-2" style="color:#6ee7b7; font-size:0.7rem; letter-spacing:0.12em;">Management</p>
            <nav class="nav flex-column gap-1 mb-4">
                <a href="/AdminVehicle/Index" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link"><i class="bi bi-bicycle fs-5"></i> Manage Vehicles</a>
                <a href="/AdminStation/Index" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link"><i class="bi bi-geo-alt fs-5"></i> Manage Stations</a>
                <a href="/AdminUser/Index" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link"><i class="bi bi-people fs-5"></i> Manage Users</a>
                <a href="/AdminTransaction/Index" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link"><i class="bi bi-currency-dollar fs-5"></i> Transactions</a>
                <a href="/AdminReport/Index" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link"><i class="bi bi-bar-chart fs-5"></i> Analytics & Reports</a>
            </nav>
            <hr class="border-secondary opacity-25 my-2">
            <p class="text-uppercase fw-semibold mt-2 mb-3 ps-2" style="color:#6ee7b7; font-size:0.7rem; letter-spacing:0.12em;">System</p>
            <nav class="nav flex-column gap-1">
                <a href="#" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link"><i class="bi bi-gear fs-5"></i> Settings</a>
                <a href="/Account/Logout" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link"><i class="bi bi-box-arrow-right fs-5"></i> Logout</a>
            </nav>
        </div>
    </div>

    <!-- Page Wrapper -->
    <div class="d-flex" style="min-height: calc(100vh - 64px);">

        <!-- Sidebar Desktop -->
        <div id="desktopSidebar" class="text-white flex-shrink-0 d-none d-md-flex flex-column py-4 px-3"
            style="width:270px; background-color:#65869D; overflow:hidden; transition: width 0.3s ease;">

            <p class="text-uppercase fw-semibold mb-3 ps-2" style="color:#6ee7b7; font-size:0.7rem; letter-spacing:0.12em;">Management</p>

            <nav class="nav flex-column gap-1 mb-4">
                <a href="/AdminVehicle/Index" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link">
                    <i class="bi bi-bicycle fs-5"></i>
                    <span class="sidebar-label">Manage Vehicles</span>
                </a>
                <a href="/AdminStation/Index" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link">
                    <i class="bi bi-geo-alt fs-5"></i>
                    <span class="sidebar-label">Manage Stations</span>
                </a>
                <a href="/AdminUser/Index" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link">
                    <i class="bi bi-people fs-5"></i>
                    <span class="sidebar-label">Manage Users</span>
                </a>
                <a href="/AdminTransaction/Index" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link">
                    <i class="bi bi-currency-dollar fs-5"></i>
                    <span class="sidebar-label">Transactions</span>
                </a>
                <a href="/AdminReport/Index" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link">
                    <i class="bi bi-bar-chart fs-5"></i>
                    <span class="sidebar-label">Analytics & Reports</span>
                </a>
            </nav>

            <hr class="border-secondary opacity-25 my-2">

            <p class="text-uppercase fw-semibold mt-2 mb-3 ps-2" style="color:#6ee7b7; font-size:0.7rem; letter-spacing:0.12em;">System</p>

            <nav class="nav flex-column gap-1">
                <a href="#" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link">
                    <i class="bi bi-gear fs-5"></i>
                    <span class="sidebar-label">Settings</span>
                </a>
                <a href="/Account/Logout" class="nav-link text-white rounded-3 px-3 py-2 d-flex align-items-center gap-3 sidebar-link">
                    <i class="bi bi-box-arrow-right fs-5"></i>
                    <span class="sidebar-label">Logout</span>
                </a>
            </nav>

        </div>

        <!-- Main Content -->
        <div class="flex-grow-1 p-4 overflow-auto">
            @RenderBody()
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        .sidebar-link:hover { background-color: rgba(255,255,255,0.12); }
        .sidebar-link.active { background-color: rgba(255,255,255,0.18); }
    </style>

    <script>
        function toggleSidebar() {
            if (window.innerWidth < 768) {
                // Mobile: Bootstrap Offcanvas
                bootstrap.Offcanvas.getOrCreateInstance(document.getElementById('mobileSidebar')).toggle();
            } else {
                // Desktop: collapse width
                const sidebar = document.getElementById('desktopSidebar');
                const collapsed = sidebar.style.width === '64px';
                sidebar.style.width = collapsed ? '270px' : '64px';
                sidebar.querySelectorAll('.sidebar-label, p').forEach(el => {
                    el.style.display = collapsed ? '' : 'none';
                });
            }
        }
    </script>

</body>
</html>