@model List<SaigonRideProject.Models.Station>
@if (Context.Session.GetString("Email") != null)
{
    <div class="alert alert-success">
        Welcome, @Context.Session.GetString("Email")
    </div>
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="position-absolute start-0 end-0"
     style="background-image: url('/img/header.png');
    background-size: cover;
    background-position: center;
    min-height: 80vh;
    width: 100vw;">

    <div class="container-fluid px-3 px-md-5 mt-4 mt-md-5">
        <div class="row align-items-center py-4 py-md-5">
            
            <div class="col-12 col-md-8 col-lg-6 ps-2 ps-md-5 text-center text-md-start">

                <span class="badge bg-white text-secondary rounded-pill px-3 py-2 mb-3 mb-md-4 shadow-sm text-uppercase fw-normal"
                      style="--bs-bg-opacity: .7;">
                    Urban Breeze Experience
                </span>

                <h1 class="fw-bold text-dark mb-3 display-4 display-md-2 display-lg-1">
                    Ride Smart.<br>
                    <span style="color:#3E637D;">Move Free.</span>
                </h1>

                <p class="lead text-secondary mb-4 mb-md-5 fs-6 fs-md-5 w-100 w-md-75 mx-auto mx-md-0">
                    Unlock the city with SaigonRide - smart, flexible, and eco-friendly transportation at your fingertips.
                </p>

                <div class="d-flex flex-column flex-sm-row gap-2 gap-md-3 justify-content-center justify-content-md-start">
                    
                    <a asp-controller="Account" asp-action="Register"
                           class="btn btn-lg rounded-pill px-4 py-2 shadow-sm border-0 text-white"
                           style="background-color: #5E96BD;">
                        Rent Now
                    </a>

                    <a asp-controller="Account" asp-action="Login"
                           class="btn btn-lg rounded-pill px-4 py-2 border-0 text-dark"
                           style="background-color: rgba(255, 255, 255, 0.5);">
                        Explore Fleet
                    </a>

                </div>

            </div>
        </div>
    </div>
</div>

<section class="py-5 bg-white">
    <div class="container py-md-5">
        <div class="row align-items-center g-4 g-lg-5">
            
            <div class="col-12 col-md-6">
                <div class="p-2 p-md-0">
                    <img src="/img/vehicle.png" 
                         class="img-fluid shadow-sm" 
                         style="border-radius: 40px; background-color: #F0F4F9;" 
                         alt="Mobility">
                </div>
            </div>

            <div class="col-12 col-md-6 px-4 px-md-2">
                <h2 class="fw-bold text-dark display-5 mb-4" style="line-height: 1.2;">
                    Simple, healthy, and effortless mobility.
                </h2>
                
                <p class="text-secondary mb-5 fs-6 fs-md-5">
                    Enjoy a smooth ride through the city with our lightweight and easy-to-use standard bikes. 
                </p>

                <div class="row g-3">
                    <div class="col-6">
                        <div class="p-3 p-md-4 border-0 shadow-sm bg-white h-100" style="border-radius: 25px;">
                            <div class="mb-3">
                                <i class="bi bi-bicycle fs-1" style="color: #3E637D;"></i>
                            </div>
                            <h6 class="fw-bold text-dark mb-2">Ergonomic Design</h6>
                            <p class="text-muted small mb-0">Built for the human body, ensuring comfort.</p>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="p-3 p-md-4 border-0 shadow-sm bg-white h-100" style="border-radius: 25px;">
                            <div class="mb-3">
                                <i class="bi bi-leaf fs-1" style="color: #3E637D;"></i>
                            </div>
                            <h6 class="fw-bold text-dark mb-2">Zero Emissions</h6>
                            <p class="text-muted small mb-0">100% powered for a cleaner planet.</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="py-5" style="background: #F8F9FD;">
    <div class="container py-md-4">

        <div class="text-center mb-5">
            <h2 class="fw-bold display-5" style="color: #2d3440;">
                Our Premium Fleet
            </h2>
            <div class="mx-auto mt-3"
                 style="width: 60px; height: 4px; background: #3E637D; border-radius: 10px;">
            </div>
        </div>

        <div class="row justify-content-center g-4">

            <div class="col-12 col-xl-5 col-lg-6">
                <div class="p-4 p-md-5 h-100 shadow-sm border-0 d-flex align-items-center justify-content-between"
                     style="background: #F0F4F9; border-radius: 40px;">

                    <div class="bg-white p-3 rounded-4 shadow-sm flex-shrink-0" style="width: 45%;">
                        <img src="/img/bike.png"
                             class="img-fluid"
                             alt="Standard Bike">
                    </div>

                    <div class="ps-4 flex-grow-1">
                        <h4 class="fw-bold mb-3 text-dark">
                            Standard Bike<br>Specs
                        </h4>

                        <ul class="mb-0 ps-0"
                            style="list-style: none; padding-left: 0; margin: 0;">

                            <li class="mb-2 d-flex align-items-start small text-secondary">
                                <i class="bi bi-check-circle me-2 mt-1"></i>
                                <span>No battery required</span>
                            </li>

                            <li class="mb-2 d-flex align-items-start small text-secondary">
                                <i class="bi bi-check-circle me-2 mt-1"></i>
                                <span>Lightweight frame for easy control</span>
                            </li>

                            <li class="mb-2 d-flex align-items-start small text-secondary">
                                <i class="bi bi-check-circle me-2 mt-1"></i>
                                <span>Comfortable seat for medium trips</span>
                            </li>

                            <li class="d-flex align-items-start small text-secondary">
                                <i class="bi bi-check-circle me-2 mt-1"></i>
                                <span>Perfect for eco-commuting</span>
                            </li>
                        </ul>
                    </div>

                </div>
            </div>

            <div class="col-12 col-xl-5 col-lg-6">
                <div class="p-4 p-md-5 h-100 shadow-sm border-0 d-flex align-items-center justify-content-between"
                     style="background: #b3d3ec; border-radius: 40px;">

                    <div class="pe-4 flex-grow-1">
                        <h4 class="fw-bold mb-3" style="color: #2D5A7F;">
                            E-Scooter<br>Specs
                        </h4>

                        <ul class="mb-0 ps-0"
                            style="list-style: none; padding-left: 0; margin: 0;">

                            <li class="mb-2 d-flex align-items-start small text-secondary">
                                <i class="bi bi-lightning-charge me-2 mt-1"></i>
                                <span>Battery range up to 25-40 km</span>
                            </li>

                            <li class="mb-2 d-flex align-items-start small text-secondary">
                                <i class="bi bi-lightning-charge me-2 mt-1"></i>
                                <span>Max speed &lt; 25 km/h</span>
                            </li>

                            <li class="mb-2 d-flex align-items-start small text-secondary">
                                <i class="bi bi-lightning-charge me-2 mt-1"></i>
                                <span>Digital display (battery & speed)</span>
                            </li>

                            <li class="d-flex align-items-start small text-secondary">
                                <i class="bi bi-lightning-charge me-2 mt-1"></i>
                                <span>Built-in smart lock system</span>
                            </li>
                        </ul>
                    </div>

                    <div class="bg-white p-3 rounded-4 shadow-sm flex-shrink-0" style="width: 45%;">
                        <img src="/img/e-scooter.png"
                             class="img-fluid"
                             alt="E-Scooter">
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>