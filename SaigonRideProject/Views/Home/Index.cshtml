@model List<SaigonRideProject.Models.Station>

@if (Context.Session.GetString("Email") != null)
{
    <div class="alert alert-success mt-2">
        Welcome, @Context.Session.GetString("Email")
    </div>
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<header class="vw-100 position-relative start-50 translate-middle-x d-flex align-items-center shadow-sm"
        style="background: url('/img/header.png') no-repeat center center;
    background-size: cover;
    min-height: 85vh;
    margin-top: -24px;">

    <div class="container px-3 px-md-5">
        <div class="row align-items-center py-4 py-md-5">
            <div class="col-12 col-md-8 col-lg-6 ps-2 ps-md-5 text-center text-md-start">

                <span class="badge bg-white text-secondary rounded-pill px-3 py-2 mb-3 mb-md-4 shadow-sm text-uppercase fw-normal"
                      style="--bs-bg-opacity: .7;">
                    Urban Breeze Experience
                </span>

                <h1 class="fw-bold text-dark mb-3 display-4 display-md-2 display-lg-1">
                    Ride Smart.<br>
                    <span style="color:#3E637D;">Move Free.</span>
                </h1>

                <p class="lead text-secondary mb-4 mb-md-5 fs-6 fs-md-5 w-100 w-md-75 mx-auto mx-md-0">
                    Unlock the city with SaigonRide - smart, flexible, and eco-friendly transportation at your fingertips.
                </p>

                <div class="d-flex flex-column flex-sm-row gap-2 gap-md-3 justify-content-center justify-content-md-start">
                    <a asp-controller="Account" asp-action="Register"
                           class="btn btn-lg rounded-pill px-4 py-2 shadow-sm border-0 text-white fw-bold"
                           style="background-color: #5E96BD;">
                        Rent Now
                    </a>
                    <a asp-controller="Account" asp-action="Login"
                           class="btn btn-lg rounded-pill px-4 py-2 border-0 text-dark fw-bold"
                           style="background-color: rgba(255, 255, 255, 0.5);">
                        Explore Fleet
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>

<section class="py-5 vw-100 position-relative start-50 translate-middle-x" style="background-color: #F0F4F9;">
    <div class="container py-2 py-md-5">
        <div class="row align-items-center justify-content-center g-4 g-lg-5">
            
            <div class="col-11 col-sm-9 col-md-6 col-lg-5">
                <div class="p-2 mb-3">
                    <img src="/img/vehicle.png"
                         class="img-fluid shadow-lg"
                         style="border-radius: 35px; transform: rotate(-3deg); backface-visibility: hidden;"
                         alt="Mobility">
                </div>
            </div>

            <div class="col-12 col-md-6 px-4 px-lg-5">
                <h2 class="fw-bold text-dark fs-2 fs-md-1 display-lg-5 mb-4" style="line-height: 1.1; letter-spacing: -1px;">
                    Simple, healthy, and effortless mobility.
                </h2>
                
                <p class="text-secondary mb-5 fs-6" style="max-width: 30rem; line-height: 1.6;">
                    Enjoy a smooth ride through the city with our lightweight and easy-to-use standard bikes. Designed for the urban environment, our fleet prioritizes comfort and agility.
                </p>

                <div class="row g-3 align-items-stretch">
                    <div class="col-6">
                        <div class="bg-white shadow-sm d-flex flex-column justify-content-center p-3 p-md-4 h-100"
                             style="border-radius: 35px !important; border: none;">
                            <div class="mb-2 mb-md-3">
                                <i class="bi bi-bicycle" style="color: #3E637D; font-size: calc(1.3rem + 0.6vw);"></i>
                            </div>
                            <h6 class="fw-bold text-dark mb-1 mb-md-2 fs-6">Ergonomic Design</h6>
                            <p class="text-muted mb-0 small" style="line-height: 1.4;">
                                Built for the human body, ensuring comfort on every mile.
                            </p>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="bg-white shadow-sm d-flex flex-column justify-content-center p-3 p-md-4 h-100"
                             style="border-radius: 35px !important; border: none;">
                            <div class="mb-2 mb-md-3">
                                <i class="bi bi-tree" style="color:#3E637D; font-size: calc(1.3rem + 0.6vw);"></i>
                            </div>
                            <h6 class="fw-bold text-dark mb-1 mb-md-2 fs-6">Zero Emissions</h6>
                            <p class="text-muted mb-0 small" style="line-height: 1.4;">
                                100% human or electric powered for a cleaner planet.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="pt-5 pb-0 vw-100 position-relative start-50 translate-middle-x" style="background: #F8F9FD; overflow: hidden;">
    <div class="container py-md-5">

        <div class="text-center mb-5">
            <h2 class="fw-bold display-5" style="color: #2d3440;">Our Premium Fleet</h2>
            <div class="mx-auto mt-3" style="width: 60px; height: 4px; background: #3E637D; border-radius: 10px;"></div>
        </div>

        <div class="row justify-content-center g-4 pb-5 align-items-stretch">
            <div class="col-12 col-xl-5 col-lg-6">
                <div class="p-4 p-md-5 h-100 shadow-sm border-0 d-flex align-items-center justify-content-between" style="background: #F0F4F9; border-radius: 40px;">
                    <div class="bg-white p-2 rounded-4 shadow-sm flex-shrink-0 overflow-hidden" style="width: 45%; aspect-ratio: 1 / 1; border: 2px solid #ffffff;">
                        <img src="/img/bike.png" class="w-100 h-100 object-fit-cover rounded-3" alt="Standard Bike">
                    </div>
                    <div class="ps-4 flex-grow-1 d-flex flex-column justify-content-center">
                        <h2 class="fw-bold mb-4 text-dark">Standard Bike Specs</h2>
                        <ul class="mb-0 ps-0 list-unstyled">
                            <li class="mb-2 d-flex align-items-start small text-secondary" style="min-height: 40px;">
                                <i class="bi bi-check-circle me-2" style="color: #2D5A7F;"></i>
                                <span>No battery required</span>
                            </li>
                            <li class="mb-2 d-flex align-items-start small text-secondary" style="min-height: 40px;">
                                <i class="bi bi-check-circle me-2" style="color: #2D5A7F;"></i>
                                <span>Lightweight frame for easy control</span>
                            </li>
                            <li class="mb-2 d-flex align-items-start small text-secondary" style="min-height: 40px;">
                                <i class="bi bi-check-circle me-2" style="color: #2D5A7F;"></i>
                                <span>Comfortable seat for medium trips</span>
                            </li>
                            <li class="d-flex align-items-start small text-secondary" style="min-height: 40px;">
                                <i class="bi bi-check-circle me-2" style="color: #2D5A7F;"></i>
                                <span>Perfect for eco-commuting</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-5 col-lg-6">
                <div class="p-4 p-md-5 h-100 shadow-sm border-0 d-flex align-items-center justify-content-between" style="background: #e1f0faff; border-radius: 40px;">
                    <div class="pe-4 flex-grow-1 d-flex flex-column justify-content-center">
                        <h2 class="fw-bold mb-4" style="color: #264D66;">E-Scooter Specs</h2>
                        <ul class="mb-0 ps-0 list-unstyled">
                            <li class="mb-2 d-flex align-items-start small text-dark" style="min-height: 40px;">
                                <i class="bi bi-lightning-charge me-2" style="color: #2D5A7F;"></i>
                                <span>Battery range up to 25-40 km</span>
                            </li>
                            <li class="mb-2 d-flex align-items-start small text-dark" style="min-height: 40px;">
                                <i class="bi bi-lightning-charge me-2" style="color: #2D5A7F;"></i>
                                <span>Max speed < 25 km/h</span>
                            </li>
                            <li class="mb-2 d-flex align-items-start small text-dark" style="min-height: 40px;">
                                <i class="bi bi-lightning-charge me-2" style="color: #2D5A7F;"></i>
                                <span>Digital display (battery & speed)</span>
                            </li>
                            <li class="d-flex align-items-start small text-dark" style="min-height: 40px;">
                                <i class="bi bi-lightning-charge me-2" style="color: #2D5A7F;"></i>
                                <span>Built-in smart lock system</span>
                            </li>
                        </ul>
                    </div>
                    <div class="bg-white p-2 rounded-4 shadow-sm flex-shrink-0 overflow-hidden" style="width: 45%; aspect-ratio: 1 / 1; border: 2px solid #ffffff;">
                        <img src="/img/e-scooter.png" class="w-100 h-100 object-fit-cover rounded-3" alt="E-Scooter">
                    </div>
                </div>
            </div>
        </div>

        <div class="row justify-content-center mt-5 pt-md-5">
            <div class="col-12 col-xl-10">
                <div class="text-center text-white p-5 shadow-lg overflow-hidden position-relative"
                     style="background: linear-gradient(135deg, #7EB3CD 0%, #3E637D 100%); border-radius: 50px;">
                    <div class="position-relative" style="z-index: 2;">
                        <h2 class="fw-bold display-6 mb-3">Rent a SaigonRide</h2>
                        <p class="mb-4 mx-auto opacity-75" style="max-width: 600px;">
                            Ready to transform your urban commute? Join the movement and experience the freedom of the city breeze.
                        </p>
                        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                            <a asp-controller="Account" asp-action="Register"
                                   class="btn btn-white bg-white fw-bold rounded-pill px-5 py-3 shadow"
                                   style="color:#3E637D;">
                                Start Riding
                            </a>
                            <a href="#" class="btn btn-outline-light fw-bold rounded-pill px-5 py-3" style="border-width: 2px;">Learn More</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="shadow-sm w-100 pt-5 pb-4 px-4 px-md-5"
         style="border-top-left-radius: 60px;
        border-top-right-radius: 60px;
        background-color:#F1F5F9;
        margin-top: 100px;">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-12 col-md-4 mb-4 mb-md-0">
                    <h5 class="fw-bold mb-2" style="color:#0C4A6E">SaigonRide</h5>
                    <p class="text-secondary small mb-0">
                        Moving with the Urban Breeze. Sustainable mobility for the modern explorer.
                    </p>
                </div>
                <div class="col-12 col-md-6 mb-4 mb-md-0">
                    <ul class="list-unstyled d-flex flex-wrap justify-content-md-center gap-3 gap-lg-4 mb-0">
                        <li><a href="#" class="text-decoration-none text-secondary small">Privacy Policy</a></li>
                        <li><a href="#" class="text-decoration-none text-secondary small">Terms of Service</a></li>
                        <li><a href="#" class="text-decoration-none text-secondary small">Help Center</a></li>
                        <li><a href="#" class="text-decoration-none text-secondary small">Contact</a></li>
                    </ul>
                </div>
                <div class="col-12 col-md-2 text-md-end">
                    <div class="d-flex justify-content-md-end gap-3 text-secondary fs-5">
                        <i class="bi bi-globe" style="color:#0C4A6E"></i>
                        <i class="bi bi-share" style="color:#0C4A6E"></i>
                    </div>
                </div>
            </div>
            <div class="row mt-4">
                <div class="col-12 text-center">
                    <hr class="text-muted opacity-25">
                    <p class="text-muted small mb-0 mt-3 text-uppercase fw-light d-flex align-items-center justify-content-center">
                        <i class="bi bi-c-circle me-2" style="font-size: 0.8rem;"></i>
                        <span>2024 SaigonRide. Moving with the Urban Breeze.</span>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>