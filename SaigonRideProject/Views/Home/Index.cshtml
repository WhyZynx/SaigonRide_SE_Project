@model List<SaigonRideProject.Models.Station>
@if (Context.Session.GetString("Email") != null)
{
    <div class="alert alert-success">
        Welcome, @Context.Session.GetString("Email")
    </div>
}

<div class="position-absolute start-0 end-0"
     style="background-image: url('/img/header.png');
    background-size: cover;
    background-position: center;
    min-height: 80vh;
    width: 100vw;">

    <div class="container-fluid px-3 px-md-5 mt-4 mt-md-5">
        <div class="row align-items-center py-4 py-md-5">
            
            <div class="col-12 col-md-8 col-lg-6 ps-2 ps-md-5 text-center text-md-start">

                <span class="badge bg-white text-secondary rounded-pill px-3 py-2 mb-3 mb-md-4 shadow-sm text-uppercase fw-normal"
                      style="--bs-bg-opacity: .7;">
                    Urban Breeze Experience
                </span>

                <h1 class="fw-bold text-dark mb-3 display-4 display-md-2 display-lg-1">
                    Ride Smart.<br>
                    <span style="color:#3E637D;">Move Free.</span>
                </h1>

                <p class="lead text-secondary mb-4 mb-md-5 fs-6 fs-md-5 w-100 w-md-75 mx-auto mx-md-0">
                    Unlock the city with SaigonRide - smart, flexible, and eco-friendly transportation at your fingertips.
                </p>

                <div class="d-flex flex-column flex-sm-row gap-2 gap-md-3 justify-content-center justify-content-md-start">
                    
                    <a asp-controller="Account" asp-action="Register"
                           class="btn btn-lg rounded-pill px-4 py-2 shadow-sm border-0 text-white"
                           style="background-color: #5E96BD;">
                        Rent Now
                    </a>

                    <a asp-controller="Account" asp-action="Login"
                           class="btn btn-lg rounded-pill px-4 py-2 border-0 text-dark"
                           style="background-color: rgba(255, 255, 255, 0.5);">
                        Explore Fleet
                    </a>

                </div>

            </div>
        </div>
    </div>
</div>