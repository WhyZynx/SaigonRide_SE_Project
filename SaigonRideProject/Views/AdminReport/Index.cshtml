<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-2">
        <h3 class="fw-bold mb-0">📊 System Report</h3>
    </div>

    <!-- FILTER -->
    <div class="mb-4">
        <div class="d-flex flex-wrap gap-2">

            <a href="?days=1"
                   class="btn btn-sm @(currentDays == "1" ? "btn-success" : "btn-outline-secondary")">
                Today
            </a>

            <a href="?days=7"
                   class="btn btn-sm @(currentDays == "7" ? "btn-success" : "btn-outline-secondary")">
                7 Days
            </a>

            <a href="?days=30"
                   class="btn btn-sm @(currentDays == "30" ? "btn-success" : "btn-outline-secondary")">
                30 Days
            </a>

        </div>
    </div>

    <!-- REVENUE -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">💰 Revenue Report</h5>
        <a href="/AdminReport/ExportRevenue?days=@currentDays"
               class="btn btn-success btn-sm">
            Export
        </a>
    </div>

    <div class="row g-3 mb-4">

        <div class="col-6 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <small class="text-muted">🚲 Bike</small>
                <h5 class="fw-bold">@Model.BikeRevenue.ToString("N0") đ</h5>
            </div>
        </div>

        <div class="col-6 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <small class="text-muted">🛴 E-Scooter</small>
                <h5 class="fw-bold">@Model.ScooterRevenue.ToString("N0") đ</h5>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center bg-light">
                <small class="text-muted">Total</small>
                <h4 class="fw-bold text-success">
                    @Model.TotalRevenue.ToString("N0") đ
                </h4>
            </div>
        </div>

    </div>

    <!-- TABLE 1 -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Station</th>
                            <th>Bike</th>
                            <th>Scooter</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.StationRevenues)
                        {
                            <tr>
                                <td>@s.StationName</td>
                                <td>@s.BikeRevenue</td>
                                <td>@s.ScooterRevenue</td>
                                <td class="fw-bold">@s.Total</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

    <!-- INVENTORY -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">🏢 Station Inventory</h5>
        <a href="/AdminReport/ExportInventory" class="btn btn-primary btn-sm">
            Export
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Station</th>
                            <th>Capacity</th>
                            <th>Current</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.StationStatuses)
                        {
                            <tr class="@(s.Status == "Low" ? "table-danger" : "")">
                                <td>@s.StationName</td>
                                <td>@s.Capacity</td>
                                <td>@s.Current</td>
                                <td>
                                    <span class="badge @(s.Status == "Low" ? "bg-danger" : "bg-success")">
                                        @s.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>