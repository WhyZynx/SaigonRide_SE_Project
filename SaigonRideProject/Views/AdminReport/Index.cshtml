@model SaigonRideProject.ViewModels.ReportViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var currentDays = Context.Request.Query["days"].ToString();
    if (string.IsNullOrEmpty(currentDays)) currentDays = "30";

    var total = Model.BikeRevenue + Model.ScooterRevenue;
    var income = Model.BikeRevenue + Model.ScooterRevenue;
    var expense = 0;
}

<div class="container py-4">

    <!-- HEADER -->
    <div class="mb-4">
        <h2 class="fw-bold mb-1">📊 System Report</h2>
        <div class="text-muted">
            Analytics dashboard for revenue and station performance
        </div>
    </div>

    <!-- FILTER -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">

            <div class="d-flex gap-2 flex-wrap">

                <a href="?days=1"
                   class="btn btn-sm rounded-pill @(currentDays == "1" ? "btn-success" : "btn-outline-secondary")">
                    Today
                </a>

                <a href="?days=7"
                   class="btn btn-sm rounded-pill @(currentDays == "7" ? "btn-success" : "btn-outline-secondary")">
                    7 Days
                </a>

                <a href="?days=30"
                   class="btn btn-sm rounded-pill @(currentDays == "30" ? "btn-success" : "btn-outline-secondary")">
                    30 Days
                </a>

            </div>

        </div>
    </div>

    <!-- HEADER + EXPORT -->
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">

        <h5 class="fw-bold mb-0">Revenue Overview</h5>

        <a href="/AdminReport/ExportRevenue?days=@currentDays"
           class="btn btn-success btn-sm px-3">
            Export
        </a>

    </div>

    <!-- STATS -->
    <div class="row g-3 mb-4">

        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="text-muted small">Bike Revenue</div>
                <div class="fs-3 fw-bold">@Model.BikeRevenue.ToString("N0") đ</div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="text-muted small">E-Scooter Revenue</div>
                <div class="fs-3 fw-bold">@Model.ScooterRevenue.ToString("N0") đ</div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="text-muted small">Total Revenue</div>
                <div class="fs-3 fw-bold text-success">
                    @Model.TotalRevenue.ToString("N0") đ
                </div>
            </div>
        </div>

    </div>

    <!-- REVENUE TABLE -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">

        <div class="card-header bg-white border-0 fw-semibold">
            Station Revenue Breakdown
        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr class="text-muted small">
                            <th>Station</th>
                            <th>Bike</th>
                            <th>Scooter</th>
                            <th>Total</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var s in Model.StationRevenues)
                        {
                            <tr>
                                <td class="fw-semibold">@s.StationName</td>
                                <td>@s.BikeRevenue</td>
                                <td>@s.ScooterRevenue</td>
                                <td class="fw-bold text-primary">@s.Total</td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- INVENTORY HEADER -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">

        <h5 class="fw-bold mb-0">Station Inventory</h5>

        <a href="/AdminReport/ExportInventory"
           class="btn btn-success btn-sm">
            Export
        </a>

    </div>

    <!-- INVENTORY TABLE -->
    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr class="text-muted small">
                            <th>Station</th>
                            <th>Capacity</th>
                            <th>Current</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var s in Model.StationStatuses)
                        {
                            <tr class="@(s.Status == "Low" ? "table-danger" : "")">

                                <td class="fw-semibold">@s.StationName</td>
                                <td>@s.Capacity</td>
                                <td>@s.Current</td>

                                <td>
                                    @if (s.Status == "Low")
                                    {
                                        <span class="badge bg-danger rounded-pill px-3">
                                            Low
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success rounded-pill px-3">
                                            Ok
                                        </span>
                                    }
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>