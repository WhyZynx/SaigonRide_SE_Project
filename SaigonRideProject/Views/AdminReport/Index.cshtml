@model SaigonRideProject.ViewModels.ReportViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var currentDays = Context.Request.Query["days"].ToString();
    if (string.IsNullOrEmpty(currentDays)) currentDays = "30";
}

<h3 class="mb-4">System Report</h3>

<!-- FILTER -->
<div class="mb-3">
    <div class="btn-group">
        <a href="?days=1" class="btn btn-sm @(currentDays == "1" ? "btn-success" : "btn-outline-secondary")">Today</a>
        <a href="?days=7" class="btn btn-sm @(currentDays == "7" ? "btn-success" : "btn-outline-secondary")">7 Days</a>
        <a href="?days=30" class="btn btn-sm @(currentDays == "30" ? "btn-success" : "btn-outline-secondary")">30 Days</a>
    </div>
</div>

<!-- REVENUE -->
<div class="d-flex justify-content-between align-items-center mb-2">
    <h5>Revenue Report</h5>
    <a href="/AdminReport/ExportRevenue?days=@currentDays" class="btn btn-success btn-sm">Export</a>
</div>

<div class="row g-3 mb-4">

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <small class="text-muted">Bike</small>
                <h5>@Model.BikeRevenue.ToString("N0") đ</h5>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <small class="text-muted">E-Scooter</small>
                <h5>@Model.ScooterRevenue.ToString("N0") đ</h5>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-light">
            <div class="card-body">
                <small class="text-muted">Total</small>
                <h4 class="text-success">@Model.TotalRevenue.ToString("N0") đ</h4>
            </div>
        </div>
    </div>

</div>

<div class="table-responsive mb-4">
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Station</th>
                <th>Bike</th>
                <th>Scooter</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.StationRevenues)
            {
                <tr>
                    <td>@s.StationName</td>
                    <td>@s.BikeRevenue</td>
                    <td>@s.ScooterRevenue</td>
                    <td><b>@s.Total</b></td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- INVENTORY -->
<div class="d-flex justify-content-between align-items-center mb-2">
    <h5>Station Inventory</h5>
    <a href="/AdminReport/ExportInventory" class="btn btn-primary btn-sm">Export</a>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Station</th>
                <th>Capacity</th>
                <th>Current</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.StationStatuses)
            {
                <tr class="@(s.Status == "Low" ? "table-danger" : "")">
                    <td>@s.StationName</td>
                    <td>@s.Capacity</td>
                    <td>@s.Current</td>
                    <td>
                        <span class="badge @(s.Status == "Low" ? "bg-danger" : "bg-success")">
                            @s.Status
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>