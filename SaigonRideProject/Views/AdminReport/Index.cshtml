@model SaigonRideProject.ViewModels.ReportViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var currentDays = Context.Request.Query["days"].ToString();
    if (string.IsNullOrEmpty(currentDays)) currentDays = "30";
}

<div class="container-fluid py-4" style="background-color: #f8f9fa; min-height: 100vh;">

    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1" style="color: #1a2e5a;">📊 System Report</h2>
        </div>

        <div class="bg-white p-2 rounded-4 shadow-sm border d-flex gap-2">
            <a href="?days=1"
                   class="btn btn-sm px-3 rounded-pill @(currentDays == "1" ? "btn-primary shadow-sm" : "btn-light text-muted")"
                   style="@(currentDays == "1" ? "background: #1a2e5a; border:none;" : "")">
                Today
            </a>
            <a href="?days=7"
                   class="btn btn-sm px-3 rounded-pill @(currentDays == "7" ? "btn-primary shadow-sm" : "btn-light text-muted")"
                   style="@(currentDays == "7" ? "background: #1a2e5a; border:none;" : "")">
                7 Days
            </a>
            <a href="?days=30"
                   class="btn btn-sm px-3 rounded-pill @(currentDays == "30" ? "btn-primary shadow-sm" : "btn-light text-muted")"
                   style="@(currentDays == "30" ? "background: #1a2e5a; border:none;" : "")">
                30 Days
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-primary border-4">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.75rem;">Bike Revenue</small>
                        <h3 class="fw-bold mb-0 mt-1">@Model.BikeRevenue.ToString("N0") <small class="fs-6 fw-normal">đ</small></h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-info border-4">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.75rem;">Scooter Revenue</small>
                        <h3 class="fw-bold mb-0 mt-1" style="color: #0dcaf0;">@Model.ScooterRevenue.ToString("N0") <small class="fs-6 fw-normal">đ</small></h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-success border-4" style="background: linear-gradient(to right, #ffffff, #f0fff4);">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.75rem;">Total Net Income</small>
                        <h3 class="fw-bold mb-0 mt-1 text-success">@Model.TotalRevenue.ToString("N0") <small class="fs-6 fw-normal">đ</small></h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0" style="color: #1a2e5a;"><i class="bi bi-bar-chart-line me-2"></i>Revenue by Station</h5>
                    <a href="/AdminReport/ExportRevenue?days=@currentDays" class="btn btn-sm btn-outline-success rounded-pill px-3">
                        <i class="bi bi-download me-1"></i> Export CSV
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="text-muted small text-uppercase">
                                    <th class="ps-4 py-3">Station Name</th>
                                    <th class="py-3">Bike (đ)</th>
                                    <th class="py-3">Scooter (đ)</th>
                                    <th class="py-3 text-end pe-4">Total (đ)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.StationRevenues)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold" style="color: #1a2e5a;">@s.StationName</td>
                                        <td>@s.BikeRevenue.ToString("N0")</td>
                                        <td>@s.ScooterRevenue.ToString("N0")</td>
                                        <td class="text-end pe-4">
                                            <span class="badge bg-primary-subtle text-primary rounded-pill fw-bold" style="font-size: 0.9rem;">
                                                @s.Total.ToString("N0")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0" style="color: #1a2e5a;"><i class="bi bi-box-seam me-2"></i>Inventory Status</h5>
                    <a href="/AdminReport/ExportInventory" class="btn btn-sm btn-outline-success rounded-pill px-3">
                        <i class="bi bi-file-earmark-excel me-1"></i> Export
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="text-muted small text-uppercase">
                                    <th class="ps-4 py-3">Station</th>
                                    <th class="py-3">Current/Cap</th>
                                    <th class="py-3 text-end pe-4">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.StationStatuses)
                                {
                                    <tr>
                                        <td class="ps-4 fw-semibold">@s.StationName</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height: 6px; width: 60px;">
                                                    <div class="progress-bar @(s.Status == "Low" ? "bg-danger" : "bg-success")"
                                                         style="width: @(s.Capacity > 0 ? (s.Current * 100 / s.Capacity) : 0)%"></div>
                                                </div>
                                                <small class="fw-bold">@s.Current/@s.Capacity</small>
                                            </div>
                                        </td>
                                        <td class="text-end pe-4">
                                            @if (s.Status == "Low")
                                            {
                                                <span class="badge bg-danger-subtle text-danger rounded-pill px-3">Low</span>
                                            }
                                            else if (s.Status == "Full")
                                            {
                                                <span class="badge bg-warning-subtle text-warning rounded-pill px-3">Full</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success-subtle text-success rounded-pill px-3">Normal</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-weight: 700;
        font-size: 0.7rem;
        letter-spacing: 0.8px;
        border-bottom: none;
    }
    .table tbody td {
        padding: 1rem 0.5rem;
        border-bottom: 1px solid #f2f2f2;
    }
    
    .table-danger-subtle {
        background-color: #fff5f5 !important;
    }

    .card { transition: transform 0.2s; }
    .card:hover { transform: translateY(-3px); }
</style>