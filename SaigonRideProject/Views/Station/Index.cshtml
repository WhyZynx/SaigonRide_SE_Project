@model List<SaigonRideProject.Models.Station>

@{
    ViewData["Title"] = "Stations";
}

<div class="container-fluid py-4">

    <h2 class="fw-bold mb-4">📍 Station Locations</h2>

    <div class="row g-4">

        <!-- MAP -->
        <div class="col-12 col-lg-8">

            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-2">

                    <div class="w-100 rounded-4 overflow-hidden"
                         style="height: 300px; min-height: 300px;"
                         id="map">
                        <!-- Google Map -->
                        <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                            Google Map goes here
                        </div>
                    </div>

                </div>
            </div>

        </div>

        <!-- STATION LIST -->
        <div class="col-12 col-lg-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body d-flex flex-column">

                    <h5 class="mb-3">🚲 Available Stations</h5>

                    <!-- Scroll area -->
                    <div style="max-height: 400px; overflow-y: auto;">

                        @if (Model != null && Model.Any())
                        {
                            foreach (var station in Model)
                            {
                                var percent = station.Capacity == 0 ? 0 :
                                (int)((double)station.Vehicles.Count() / station.Capacity * 100);

                                <div class="card mb-3 border-0 shadow-sm rounded-3">

                                    <div class="card-body p-3">

                                        <h6 class="fw-bold mb-1">
                                            📍 @station.Name
                                        </h6>

                                        <small class="text-muted d-block mb-2">
                                            Capacity: @station.Capacity
                                        </small>

                                        <!-- INVENTORY -->
                                        <div class="mb-1">
                                            <div class="progress" style="height:6px;">
                                                <div class="progress-bar
                                                    @(percent < 20 ? "bg-danger" : percent < 50 ? "bg-warning" : "bg-success")"
                                                     style="width:@percent%">
                                                </div>
                                            </div>
                                            <small>
                                                @station.Vehicles.Count() / @station.Capacity
                                            </small>
                                        </div>

                                        <!-- WARNING -->
                                        @if (percent < 20)
                                        {
                                            <small class="text-danger">
                                                ⚠️ Low inventory
                                            </small>
                                        }

                                    </div>

                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-info">
                                No stations available.
                            </div>
                        }

                    </div>

                </div>
            </div>

        </div>

    </div>

</div>