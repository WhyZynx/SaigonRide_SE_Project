@model List<SaigonRideProject.Models.Station>

@{
    ViewData["Title"] = "Stations";
}

<div class="container mt-4">
    <h2 class="mb-4">Station Locations</h2>

    <div class="row">
        <div class="col-md-8">
            <div class="border rounded shadow-sm d-flex align-items-center justify-content-center"
                 style="height: 500px;">
                <span>Google Map goes here</span>
            </div>
        </div>

        <div class="col-md-4">
            <h4 class="mb-3">Available Stations</h4>

            @if (Model != null && Model.Any())
            {
                @foreach (var station in Model)
                {
                    <div class="card mb-3 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@station.Name</h5>
                            <p class="mb-1">
                                Capacity: @station.Capacity
                            </p>
                            <p class="mb-0">
                                Current Inventory: @station.Vehicles.Count()
                            </p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info">
                    No stations available.
                </div>
            }
        </div>
    </div>
</div>